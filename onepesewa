        99) systemctl stop zivpn; stop_daemons; rm -rf /etc/zivpn /usr/local/bin/zivpn /usr/local/bin/onepesewa; echo "Uninstalled."; exit ;;
        0) stop_daemons; clear; echo "Goodbye!"; exit ;;
        *) echo "Invalid"; read -p "Enter..."; ;;
    esac
done

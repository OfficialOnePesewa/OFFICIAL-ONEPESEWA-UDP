# --- Core user management functions ---
add_user_core() {
    local basepass="$1" days="$2" quota="$3" devid="$4"
    [ -n "$devid" ] && finalpass="${basepass}_${devid}" || { finalpass="$basepass"; devid="None"; }
    exp=$(date -d "+$days days" +%Y-%m-%d 2>/dev/null || echo "Invalid date")
    startdate=$(date +%Y-%m-%d)
    port=$(find_free_port)
    [ -z "$port" ] && { echo "ERROR: No free ports"; return 1; }
    [ -f "$CONFIG" ] && jq --arg p "$finalpass" '.auth.config += [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
    echo "$finalpass|$exp|$quota|$port|$devid|$startdate" >> "$DB"
    echo "$finalpass|0" >> "$USAGE_DB"
    setup_tracking "$port"
    systemctl restart zivpn 2>/dev/null
    echo "SUCCESS|$finalpass|$exp|$port|$quota"
}

remove_user_core() {
    local pass="$1"
    port=$(grep "^$pass|" "$DB" 2>/dev/null | cut -d'|' -f4)
    [ -n "$port" ] && remove_tracking "$port"
    [ -f "$CONFIG" ] && jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
    sed -i "/^$pass|/d" "$DB" 2>/dev/null; sed -i "/^$pass|/d" "$USAGE_DB" 2>/dev/null
    sed -i "/^$pass|/d" "$TELEGRAM_DB" 2>/dev/null; sed -i "/^$pass|/d" "$LAST_SENT_DB" 2>/dev/null
    systemctl restart zivpn 2>/dev/null
    echo "SUCCESS|User removed"
}

renew_user_core() {
    local pass="$1" days="$2"
    oldexp=$(grep "^$pass|" "$DB" | cut -d'|' -f2)
    [ -z "$oldexp" ] && { echo "ERROR|User not found"; return 1; }
    newexp=$(date -d "$oldexp +$days days" +%Y-%m-%d 2>/dev/null || echo "$oldexp")
    sed -i "s|^$pass|$oldexp|$pass|$newexp|" "$DB"
    echo "SUCCESS|Expiry extended to $newexp"
}

reset_bw_core() {
    local pass="$1"
    port=$(grep "^$pass|" "$DB" | cut -d'|' -f4)
    [ -z "$port" ] && { echo "ERROR|User not found"; return 1; }
    iptables -Z UDP_IN_$port 2>/dev/null; iptables -Z UDP_OUT_$port 2>/dev/null
    sed -i "s|^$pass|.*|$pass|0|" "$USAGE_DB"
    echo "SUCCESS|Bandwidth reset"
}

get_user_info() {
    local pass="$1"
    user_data=$(grep "^$pass|" "$DB" 2>/dev/null)
    [ -z "$user_data" ] && { echo "ERROR|User not found"; return 1; }
    IFS='|' read -r p expiry quota port deviceid startdate <<< "$user_data"
    used_bytes=$(grep "^$pass|" "$USAGE_DB" 2>/dev/null | cut -d'|' -f2); used_bytes=${used_bytes:-0}
    quota_bytes=$(quota_to_bytes "$quota")
    remaining=$((quota_bytes - used_bytes)); [ $remaining -lt 0 ] && remaining=0
    used_fmt=$(format_bytes $used_bytes); remaining_fmt=$(format_bytes $remaining)
    days_left=$(( ($(date -d "$expiry" +%s) - $(date +%s)) / 86400 ))
    echo "SUCCESS|$pass|$expiry|$quota|$used_fmt|$remaining_fmt|$days_left|$deviceid|$port|$startdate"
}

cleanup_expired_core() {
    today=$(date +%Y-%m-%d)
    while IFS='|' read -r pass expiry quota port deviceid startdate; do
        if [[ "$expiry" < "$today" ]]; then
            [ -n "$port" ] && remove_tracking "$port"
            [ -f "$CONFIG" ] && jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
            sed -i "/^$pass|/d" "$DB"; sed -i "/^$pass|/d" "$USAGE_DB"
        fi
    done < "$DB"
    systemctl restart zivpn 2>/dev/null
    echo "SUCCESS|Cleanup done"
}

# --- Bot command processor ---
process_bot_command() {
    local chat_id="$1" text="$2"
    local cmd=$(echo "$text" | awk '{print $1}')
    local args=($(echo "$text" | cut -d' ' -f2-))

    # User registration via /start
    if [[ "$text" =~ ^/start[[:space:]]+(.+)$ ]]; then
        pass="${BASH_REMATCH[1]}"
        if grep -q "^$pass|" "$DB"; then
            grep -v "^$pass|" "$TELEGRAM_DB" 2>/dev/null > /tmp/tg_tmp
            echo "$pass|$chat_id" >> /tmp/tg_tmp; mv /tmp/tg_tmp "$TELEGRAM_DB"
            send_telegram_message "$chat_id" "вњ… Account linked! You'll receive usage updates."
        else
            send_telegram_message "$chat_id" "вќЊ Invalid password."
        fi
        return
    fi

    # Admin commands require auth
    if ! is_admin "$chat_id"; then
        [[ "$cmd" == "/help" ]] && send_telegram_message "$chat_id" "Commands: /start <password> - link account" && return
        send_telegram_message "$chat_id" "в›” Unauthorized."
        return
    fi

    case "$cmd" in
        /help)
            local msg="рџ”§ <b>Admin Commands</b>%0A/status - Server status%0A/listusers - All users%0A/userinfo &lt;pass&gt;%0A/adduser &lt;pass&gt; &lt;days&gt; &lt;quota&gt; [devid]%0A/removeuser &lt;pass&gt;%0A/renew &lt;pass&gt; &lt;days&gt;%0A/resetbw &lt;pass&gt;%0A/cleanup - Remove expired"
            if is_owner "$chat_id"; then msg+="%0Aрџ‘‘ <b>Owner</b>%0A/addadmin &lt;id&gt; &lt;name&gt;%0A/removeadmin &lt;id&gt;%0A/listadmins"; fi
            send_telegram_message "$chat_id" "$msg"
            ;;
        /status)
            fetch_geo
            local msg="рџ–Ґ <b>Server Status</b>%0AрџЊђ IP: $IP%0Aрџ“Ќ Location: $CITY, $COUNTRY%0AрџЏў ISP: $ISP%0AвљЎ Service: $(systemctl is-active zivpn)%0AвЏ± Uptime: $UPTIME%0Aрџ‘Ґ Users: $USER_COUNT"
            send_telegram_message "$chat_id" "$msg"
            ;;
        /listusers)
            local list=""; while IFS='|' read -r pass expiry quota port dev start; do list+="$pass | $expiry | $quota%0A"; done < "$DB"
            [ -z "$list" ] && list="No users."
            send_telegram_message "$chat_id" "рџ‘Ґ <b>Users:</b>%0A$list"
            ;;
        /userinfo)
            result=$(get_user_info "${args[0]}")
            if [[ "$result" == ERROR* ]]; then send_telegram_message "$chat_id" "вќЊ User not found."
            else
                IFS='|' read -r _ p expiry quota used remain days dev port start <<< "$result"
                local msg="рџ”Ќ <b>${p:0:20}</b>%0Aрџ“… Expiry: $expiry ($days days)%0Aрџ“Љ Quota: $quota%0Aрџ“€ Used: $used%0Aрџ“‰ Remain: $remain%0Aрџ“± Device: $dev%0Aрџ”Њ Port: $port"
                send_telegram_message "$chat_id" "$msg"
            fi
            ;;
        /adduser)
            [ ${#args[@]} -lt 3 ] && { send_telegram_message "$chat_id" "Usage: /adduser &lt;pass&gt; &lt;days&gt; &lt;quota&gt; [devid]"; return; }
            result=$(add_user_core "${args[0]}" "${args[1]}" "${args[2]}" "${args[3]}")
            if [[ "$result" == SUCCESS* ]]; then
                IFS='|' read -r _ finalpass exp port quota <<< "$result"
                send_telegram_message "$chat_id" "вњ… Created:%0Aрџ”‘ <code>$finalpass</code>%0Aрџ“Ў Port: $port%0Aрџ“… Expiry: $exp%0Aрџ“Љ Quota: $quota"
            else send_telegram_message "$chat_id" "вќЊ $result"; fi
            ;;
        /removeuser) send_telegram_message "$chat_id" "$(remove_user_core "${args[0]}")" ;;
        /renew) send_telegram_message "$chat_id" "$(renew_user_core "${args[0]}" "${args[1]}")" ;;
        /resetbw) send_telegram_message "$chat_id" "$(reset_bw_core "${args[0]}")" ;;
        /cleanup) cleanup_expired_core >/dev/null; send_telegram_message "$chat_id" "вњ… Cleanup done." ;;
        /addadmin)
            if ! is_owner "$chat_id"; then send_telegram_message "$chat_id" "в›” Owner only."; return; fi
            grep -v "^${args[0]}|" "$ADMINS_DB" > /tmp/adm_tmp
            echo "${args[0]}|admin|${args[1]}" >> /tmp/adm_tmp; mv /tmp/adm_tmp "$ADMINS_DB"
            send_telegram_message "$chat_id" "вњ… Admin added."
            ;;
        /removeadmin)
            if ! is_owner "$chat_id"; then send_telegram_message "$chat_id" "в›” Owner only."; return; fi
            sed -i "/^${args[0]}|/d" "$ADMINS_DB"
            send_telegram_message "$chat_id" "вњ… Admin removed."
            ;;
        /listadmins)
            if ! is_owner "$chat_id"; then return; fi
            send_telegram_message "$chat_id" "рџ‘‘ Admins:%0A$(cat "$ADMINS_DB" | sed 's/|/ - /g')"
            ;;
    esac
}

# --- Telegram listener with error logging ---
start_telegram_listener() {
    local token=$(cat /etc/zivpn/telegram_token 2>/dev/null)
    [ -z "$token" ] && return
    (
        local offset=0
        while true; do
            updates=$(curl -s "https://api.telegram.org/bot$token/getUpdates?offset=$offset&timeout=30" 2>>/var/log/opudp_tg.log)
            if echo "$updates" | grep -q '"ok":true'; then
                echo "$updates" | jq -c '.result[]' 2>/dev/null | while read update; do
                    update_id=$(echo "$update" | jq -r '.update_id')
                    offset=$((update_id + 1))
                    message=$(echo "$update" | jq -r '.message')
                    if [ "$message" != "null" ]; then
                        text=$(echo "$message" | jq -r '.text')
                        chat_id=$(echo "$message" | jq -r '.chat.id')
                        process_bot_command "$chat_id" "$text"
                    fi
                done
            fi
            sleep 2
        done
    ) &
    echo $! > /var/run/opudp_tg_listener.pid
}

# --- Update usage daemon (10s interval) ---
update_usage_db() {
    while IFS='|' read -r pass expiry quota port deviceid startdate; do
        [ -z "$port" ] || [ "$port" = "None" ] && continue
        in_bytes=$(iptables -L UDP_IN_$port -v -x 2>/dev/null | grep -oP '\d+' | head -1)
        out_bytes=$(iptables -L UDP_OUT_$port -v -x 2>/dev/null | grep -oP '\d+' | head -1)
        total=$(( ${in_bytes:-0} + ${out_bytes:-0} ))
        prev=$(grep "^$pass|" "$USAGE_DB" 2>/dev/null | cut -d'|' -f2); prev=${prev:-0}
        grep -v "^$pass|" "$USAGE_DB" > /tmp/usage_tmp
        echo "$pass|$total" >> /tmp/usage_tmp; mv /tmp/usage_tmp "$USAGE_DB"
        # First activity notification
        last_sent=$(grep "^$pass|" "$LAST_SENT_DB" 2>/dev/null | cut -d'|' -f2)
        if [ $total -gt $prev ] && [ $((total - prev)) -gt 1024 ] && ([ -z "$last_sent" ] || [ $(($(date +%s) - last_sent)) -gt 3600 ]); then
            chat_id=$(grep "^$pass|" "$TELEGRAM_DB" 2>/dev/null | cut -d'|' -f2)
            if [ -n "$chat_id" ]; then
                used_fmt=$(format_bytes $total); quota_bytes=$(quota_to_bytes "$quota")
                remaining=$((quota_bytes - total)); [ $remaining -lt 0 ] && remaining=0
                days_left=$(( ($(date -d "$expiry" +%s) - $(date +%s)) / 86400 ))
                msg="рџ”” <b>VPN Session</b>%0Aрџ‘¤ ${pass:0:15}%0Aрџ“… Expiry: $expiry ($days_left days)%0Aрџ“Љ Quota: $quota%0Aрџ“€ Used: $used_fmt%0Aрџ“‰ Remain: $(format_bytes $remaining)%0AрџЊђ $IP ($CITY, $COUNTRY)"
                send_telegram_message "$chat_id" "$msg"
                grep -v "^$pass|" "$LAST_SENT_DB" > /tmp/last_tmp
                echo "$pass|$(date +%s)" >> /tmp/last_tmp; mv /tmp/last_tmp "$LAST_SENT_DB"
            fi
        fi
        # Quota enforcement
        quota_bytes=$(quota_to_bytes "$quota")
        if [ $quota_bytes -gt 0 ] && [ $total -ge $quota_bytes ] && ! grep -q "^$pass|.*PAUSED" "$DB"; then
            sed -i "s|^$pass|$pass [PAUSED]|" "$DB"
            jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
            systemctl restart zivpn 2>/dev/null
            chat_id=$(grep "^$pass|" "$TELEGRAM_DB" 2>/dev/null | cut -d'|' -f2)
            [ -n "$chat_id" ] && send_telegram_message "$chat_id" "в›” Quota exhausted. Service paused."
        fi
    done < "$DB"
}

start_usage_daemon() {
    [ -f "$DAEMON_PID_FILE" ] && kill $(cat "$DAEMON_PID_FILE") 2>/dev/null
    ( while true; do /usr/local/bin/onepesewa --update-usage; sleep 10; done ) &
    echo $! > "$DAEMON_PID_FILE"
}

stop_daemons() {
    [ -f "$DAEMON_PID_FILE" ] && kill $(cat "$DAEMON_PID_FILE") 2>/dev/null && rm -f "$DAEMON_PID_FILE"
    [ -f /var/run/opudp_tg_listener.pid ] && kill $(cat /var/run/opudp_tg_listener.pid) 2>/dev/null && rm -f /var/run/opudp_tg_listener.pid
}


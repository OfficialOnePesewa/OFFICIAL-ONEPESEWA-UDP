# ------------------ UDP Custom Helpers ------------------
udpc_add_user() {
    local days=$1
    local username=$(openssl rand -hex 4)
    local password=$(openssl rand -hex 6)
    local exp_date=$(date -d "+$days days" +%Y-%m-%d)
    
    # Add to UDP Custom users.json
    local tmp=$(mktemp)
    jq --arg user "$username" --arg pass "$password" --arg exp "$exp_date" \
        '. + {($user): {"password": $pass, "expiry": $exp}}' "$UDPC_USERS" > "$tmp" 2>/dev/null
    mv "$tmp" "$UDPC_USERS"
    systemctl restart udp-custom 2>/dev/null
    
    echo "$username|$password|$exp_date"
}

udpc_remove_user() {
    local username=$1
    jq "del(.\"$username\")" "$UDPC_USERS" > /tmp/udpc_tmp.json && mv /tmp/udpc_tmp.json "$UDPC_USERS"
    systemctl restart udp-custom 2>/dev/null
}

udpc_list_users() {
    if [ -f "$UDPC_USERS" ]; then
        echo -e "\n${CYN}UDP Custom Users:${RST}"
        echo "Username | Password | Expiry"
        echo "--------------------------------"
        jq -r 'to_entries[] | "\(.key) | \(.value.password) | \(.value.expiry)"' "$UDPC_USERS" 2>/dev/null
    else
        echo -e "${RED}No UDP Custom users found.${RST}"
    fi
}

# ------------------ Add User (Unified) ------------------
add_user() {
    echo -e "\n${YLW}Select Protocol:${RST}"
    echo "  1) ZIVPN"
    echo "  2) UDP Custom"
    read -p "Choice [1-2]: " proto
    case $proto in
        1)
            echo -e "\n${YLW}╭────────────────── CREATE ZIVPN USER ──────────────────╮${RST}"
            read -p "$(echo -e "${GRN}Base Password  : ${RST}")" basepass
            read -p "$(echo -e "${GRN}Validity (Days): ${RST}")" days
            read -p "$(echo -e "${GRN}Quota (GB/MB)  : ${RST}")" quota
            read -p "$(echo -e "${GRN}Device ID      : ${RST}")" devid
            echo -e "${YLW}╰──────────────────────────────────────────────────────╯${RST}"
            
            [ -n "$devid" ] && finalpass="${basepass}_${devid}" || finalpass="$basepass"
            exp=$(date -d "+$days days" +%Y-%m-%d)
            port=$(find_free_port)
            jq --arg p "$finalpass" '.auth.config += [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
            echo "$finalpass|$exp|$quota|$port|${devid:-None}|$(date +%Y-%m-%d)" >> "$DB"
            echo "$finalpass|0" >> "$USAGE_DB"
            systemctl restart zivpn 2>/dev/null
            
            fetch_geo
            echo -e "\n${CYN}╭──────────────────────────────────────────────────────╮${RST}"
            echo -e "${CYN}│  ${GRN}${BOLD}🎉 ZIVPN USER CREATED SUCCESSFULLY 🎉${RST}${CYN}                 │${RST}"
            echo -e "${CYN}├──────────────────────────────────────────────────────┤${RST}"
            echo -e "${CYN}│${RST} ${YLW}🔑 UDP Password :${RST} ${WHT}$finalpass${RST}"
            echo -e "${CYN}│${RST}   ${DIM}(Copy the entire string above)${RST}"
            echo -e "${CYN}│${RST} ${YLW}📡 Assigned Port:${RST} ${WHT}$port${RST}"
            echo -e "${CYN}│${RST} ${YLW}⏳ Expiry       :${RST} ${WHT}$exp ($days Days)${RST}"
            echo -e "${CYN}│${RST} ${YLW}📊 Quota        :${RST} ${WHT}$quota${RST}"
            echo -e "${CYN}│${RST} ${YLW}📱 Device ID    :${RST} ${WHT}${devid:-None}${RST}"
            echo -e "${CYN}├──────────────────────────────────────────────────────┤${RST}"
            echo -e "${CYN}│${RST} ${MAG}🌍 Server IP    :${RST} ${WHT}$IP${RST}"
            echo -e "${CYN}│${RST} ${MAG}📍 Location     :${RST} ${WHT}$CITY, $COUNTRY${RST}"
            echo -e "${CYN}│${RST} ${MAG}🏢 ISP          :${RST} ${WHT}$ISP${RST}"
            echo -e "${CYN}╰──────────────────────────────────────────────────────╯${RST}\n"
            read -p "Press Enter to continue..."
            ;;
        2)
            echo -e "\n${YLW}╭────────────────── CREATE UDP CUSTOM USER ──────────────────╮${RST}"
            read -p "$(echo -e "${GRN}Validity (Days): ${RST}")" days
            echo -e "${YLW}╰─────────────────────────────────────────────────────────────╯${RST}"
            
            creds=$(udpc_add_user "$days")
            username=$(echo "$creds" | cut -d'|' -f1)
            password=$(echo "$creds" | cut -d'|' -f2)
            expiry=$(echo "$creds" | cut -d'|' -f3)
            
            fetch_geo
            echo -e "\n${CYN}╭──────────────────────────────────────────────────────╮${RST}"
            echo -e "${CYN}│  ${GRN}${BOLD}🎉 UDP CUSTOM USER CREATED SUCCESSFULLY 🎉${RST}${CYN}            │${RST}"
            echo -e "${CYN}├──────────────────────────────────────────────────────┤${RST}"
            echo -e "${CYN}│${RST} ${YLW}👤 Username     :${RST} ${WHT}$username${RST}"
            echo -e "${CYN}│${RST} ${YLW}🔑 Password     :${RST} ${WHT}$password${RST}"
            echo -e "${CYN}│${RST} ${YLW}📡 Port         :${RST} ${WHT}36712${RST}"
            echo -e "${CYN}│${RST} ${YLW}🌐 Gateway      :${RST} ${WHT}7800${RST}"
            echo -e "${CYN}│${RST} ${YLW}⏳ Expiry       :${RST} ${WHT}$expiry ($days Days)${RST}"
            echo -e "${CYN}├──────────────────────────────────────────────────────┤${RST}"
            echo -e "${CYN}│${RST} ${MAG}🌍 Server IP    :${RST} ${WHT}$IP${RST}"
            echo -e "${CYN}│${RST} ${MAG}📍 Location     :${RST} ${WHT}$CITY, $COUNTRY${RST}"
            echo -e "${CYN}│${RST} ${MAG}🏢 ISP          :${RST} ${WHT}$ISP${RST}"
            echo -e "${CYN}╰──────────────────────────────────────────────────────╯${RST}\n"
            read -p "Press Enter to continue..."
            ;;
        *) echo -e "${RED}Invalid choice.${RST}"; read -p "Press Enter...";;
    esac
}

# ------------------ Remove User (Unified) ------------------
remove_user() {
    echo -e "\n${YLW}Select Protocol:${RST}"
    echo "  1) ZIVPN"
    echo "  2) UDP Custom"
    read -p "Choice [1-2]: " proto
    case $proto in
        1)
            read -p "ZIVPN Password: " pass
            jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
            sed -i "/^$pass|/d" "$DB" "$USAGE_DB"
            systemctl restart zivpn 2>/dev/null
            echo -e "${GRN}ZIVPN user removed.${RST}"
            ;;
        2)
            read -p "UDP Custom Username: " username
            udpc_remove_user "$username"
            echo -e "${GRN}UDP Custom user removed.${RST}"
            ;;
        *) echo -e "${RED}Invalid.${RST}";;
    esac
    read -p "Press Enter to continue..."
}

# ------------------ Service Control ------------------
service_control() {
    action=$1
    echo -e "${YLW}Select service:${RST}"
    echo "  1) ZIVPN only"
    echo "  2) UDP Custom only"
    echo "  3) Both"
    read -p "Choice: " svc
    case $svc in
        1) systemctl $action zivpn;;
        2) systemctl $action udp-custom;;
        3) systemctl $action zivpn udp-custom;;
        *) echo "Invalid";;
    esac
}

# ------------------ Bot CLI Mode ------------------
if [[ "$1" == "--bot-"* ]]; then
    cmd="${1#--bot-}"
    shift
    case "$cmd" in
        adduser) basepass="$1"; days="$2"; quota="$3"; devid="$4"
            [ -n "$devid" ] && finalpass="${basepass}_${devid}" || finalpass="$basepass"
            exp=$(date -d "+$days days" +%Y-%m-%d)
            port=$(find_free_port)
            jq --arg p "$finalpass" '.auth.config += [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
            echo "$finalpass|$exp|$quota|$port|$devid|$(date +%Y-%m-%d)" >> "$DB"
            echo "$finalpass|0" >> "$USAGE_DB"
            systemctl restart zivpn 2>/dev/null
            echo "SUCCESS|$finalpass|$exp|$port|$quota"
            ;;
        removeuser) pass="$1"
            jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
            sed -i "/^$pass|/d" "$DB" "$USAGE_DB"
            systemctl restart zivpn 2>/dev/null
            echo "✅ User removed."
            ;;
        renew) pass="$1"; days="$2"
            oldexp=$(grep "^$pass|" "$DB" | cut -d'|' -f2)
            newexp=$(date -d "$oldexp +$days days" +%Y-%m-%d)
            sed -i "s|^$pass|$oldexp|$pass|$newexp|" "$DB"
            echo "✅ Expiry extended to $newexp"
            ;;
        cleanup) today=$(date +%Y-%m-%d)
            while IFS='|' read -r p exp q port dev start; do
                [[ "$exp" < "$today" ]] && jq --arg p "$p" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG" && sed -i "/^$p|/d" "$DB" "$USAGE_DB"
            done < "$DB"
            systemctl restart zivpn 2>/dev/null
            echo "✅ Cleanup done."
            ;;
        *) echo "Unknown bot command"; exit 1 ;;
    esac
    exit 0
fi

# ------------------ Main Loop ------------------
fetch_geo

while true; do
    get_sysinfo
    print_header
    print_info
    print_menu
    read -p "$(echo -e "${CYN}Enter your choice [0-99]: ${RST}")" opt
    case $opt in
        1) service_control start; read -p "Press Enter..." ;;
        2) service_control stop; read -p "Press Enter..." ;;
        3) service_control restart; read -p "Press Enter..." ;;
        4) systemctl status zivpn --no-pager; systemctl status udp-custom --no-pager; read -p "Press Enter..." ;;
        5) echo -e "\n${CYN}ZIVPN Users:${RST}"; column -t -s "|" "$DB"; read -p "Press Enter..." ;;
        6) add_user ;;
        7) remove_user ;;
        8) read -p "ZIVPN Password: " p; read -p "Days: " d; /usr/local/bin/onepesewa --bot-renew "$p" "$d"; read -p "Press Enter..." ;;
        9) /usr/local/bin/onepesewa --bot-cleanup; read -p "Press Enter..." ;;
        10) echo "ZIVPN Usage:"; cat "$USAGE_DB"; read -p "Press Enter..." ;;
        11) journalctl -u zivpn -u udp-custom -f ;;
        12) echo "Restore function"; read -p "Press Enter..." ;;
        13) read -p "Minutes: " m; pass="trial_$(openssl rand -hex 2)"
            /usr/local/bin/onepesewa --bot-adduser "$pass" 1 "100MB" "trial"
            echo "ZIVPN Trial: $pass"; (sleep $((m*60)); /usr/local/bin/onepesewa --bot-removeuser "$pass") & read -p "Press Enter..." ;;
        14) read -p "Bot Token: " t; echo "$t" > /etc/zivpn/telegram_token
            systemctl enable opudp-bot 2>/dev/null; systemctl restart opudp-bot 2>/dev/null
            echo "Bot configured."; read -p "Press Enter..." ;;
        15) udpc_list_users; read -p "Press Enter..." ;;
        99) systemctl stop zivpn udp-custom; rm -rf /etc/zivpn /usr/local/bin/zivpn /usr/local/bin/onepesewa /root/udp; echo "Uninstalled."; exit ;;
        0) clear; echo "Goodbye!"; exit ;;
        *) echo -e "${RED}Invalid.${RST}"; read -p "Press Enter..." ;;
    esac
done

# --- Find next available port ---
find_free_port() {
    local port=$PORT_START
    while [ $port -le $PORT_END ]; do
        if ! grep -q "|$port|" "$DB" 2>/dev/null; then
            echo $port
            return
        fi
        port=$((port+1))
    done
    echo ""
}

# --- Convert quota to bytes ---
quota_to_bytes() {
    local q="$1"
    q=$(echo "$q" | tr '[:upper:]' '[:lower:]')
    if [[ "$q" =~ ^([0-9.]+)gb$ ]]; then
        echo "${BASH_REMATCH[1]} * 1073741824" | bc | cut -d. -f1
    elif [[ "$q" =~ ^([0-9.]+)mb$ ]]; then
        echo "${BASH_REMATCH[1]} * 1048576" | bc | cut -d. -f1
    else
        echo "0"
    fi
}

# --- Format bytes to human readable ---
format_bytes() {
    local b=$1
    if [ $b -ge 1073741824 ]; then
        echo "$(echo "scale=2; $b/1073741824" | bc) GB"
    elif [ $b -ge 1048576 ]; then
        echo "$(echo "scale=2; $b/1048576" | bc) MB"
    elif [ $b -ge 1024 ]; then
        echo "$(echo "scale=2; $b/1024" | bc) KB"
    else
        echo "$b B"
    fi
}

# --- Setup iptables tracking for a user ---
setup_tracking() {
    local pass="$1"
    local port="$2"
    iptables -I INPUT -p udp --dport $port -j ACCEPT 2>/dev/null
    iptables -I FORWARD -p udp --dport $port -j ACCEPT 2>/dev/null
    # Add to NAT
    iptables -t nat -A PREROUTING -p udp --dport $port -j DNAT --to-destination :5667 2>/dev/null
    # Add counting rules (using custom chains)
    iptables -N UDP_IN_$port 2>/dev/null
    iptables -N UDP_OUT_$port 2>/dev/null
    iptables -I INPUT -p udp --dport $port -j UDP_IN_$port 2>/dev/null
    iptables -I OUTPUT -p udp --sport $port -j UDP_OUT_$port 2>/dev/null
}

# --- Remove iptables tracking for a user ---
remove_tracking() {
    local port="$1"
    iptables -D INPUT -p udp --dport $port -j UDP_IN_$port 2>/dev/null
    iptables -D OUTPUT -p udp --sport $port -j UDP_OUT_$port 2>/dev/null
    iptables -F UDP_IN_$port 2>/dev/null
    iptables -X UDP_IN_$port 2>/dev/null
    iptables -F UDP_OUT_$port 2>/dev/null
    iptables -X UDP_OUT_$port 2>/dev/null
    iptables -D INPUT -p udp --dport $port -j ACCEPT 2>/dev/null
    iptables -t nat -D PREROUTING -p udp --dport $port -j DNAT --to-destination :5667 2>/dev/null
}

# --- Update usage database from iptables counters ---
update_usage_db() {
    while IFS='|' read -r pass expiry quota port deviceid; do
        if [ -n "$port" ] && [ "$port" != "None" ]; then
            in_bytes=$(iptables -L UDP_IN_$port -v -x 2>/dev/null | grep -oP '\d+' | head -1)
            out_bytes=$(iptables -L UDP_OUT_$port -v -x 2>/dev/null | grep -oP '\d+' | head -1)
            total=$(( ${in_bytes:-0} + ${out_bytes:-0} ))
            # Update usage.db: pass|total_bytes
            grep -v "^$pass|" "$USAGE_DB" 2>/dev/null > /tmp/usage_tmp
            echo "$pass|$total" >> /tmp/usage_tmp
            mv /tmp/usage_tmp "$USAGE_DB"
        fi
    done < "$DB"
}

# --- Get current usage for a password ---
get_usage() {
    local pass="$1"
    grep "^$pass|" "$USAGE_DB" 2>/dev/null | cut -d'|' -f2 | head -1
}

# --- Add User (with device binding + bandwidth tracking) ---
add_user() {
    echo -e "\n${YLW}в•ӯв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ CREATE NEW USER в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®${RST}"
    read -p "$(echo -e "${GRN}Base Password  : ${RST}")" basepass
    read -p "$(echo -e "${GRN}Validity (Days): ${RST}")" days
    read -p "$(echo -e "${GRN}Quota (GB/MB)  : ${RST}")" quota
    read -p "$(echo -e "${GRN}Device ID      : ${RST}")" devid
    echo -e "${YLW}в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ${RST}"

    if [ -n "$devid" ]; then
        finalpass="${basepass}_${devid}"
    else
        finalpass="$basepass"
        devid="None"
    fi

    exp=$(date -d "+$days days" +%Y-%m-%d 2>/dev/null || echo "Invalid date")

    # Find free port
    port=$(find_free_port)
    if [ -z "$port" ]; then
        echo -e "${RED}Error: No free ports available!${RST}"
        read -p "Press Enter to continue..."
        return
    fi

    # Add to ZIVPN config
    if [ -f "$CONFIG" ]; then
        jq --arg p "$finalpass" '.auth.config += [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
    fi
    echo "$finalpass|$exp|$quota|$port|$devid" >> "$DB"
    echo "$finalpass|0" >> "$USAGE_DB"

    # Setup iptables tracking
    setup_tracking "$finalpass" "$port"


        6) do_add_user ;;
        7) do_remove_user ;;
        8) do_renew_user ;;
        10) do_conn_stats ;;
        11) do_bw_expiry ;;
        15) do_backup ;;
        18) do_update ;;
        21) do_bbr ;;
        31|32) toggle_user_status ;;
        99) do_uninstall ;;
        0) echo -e "\n\( {GRN}Goodbye! \){RST}"; exit 0 ;;
        *) echo -e "\( {RED}Invalid option. \){RST}" ;;
    esac
    press_enter
done

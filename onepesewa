remove_user() {
    read -p "$(echo -e "${GRN}ZIVPN Password to remove: ${RST}")" pass
    port=$(grep "^$pass|" "$DB" 2>/dev/null | cut -d'|' -f4)
    [ -n "$port" ] && remove_tracking "$port"
    jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
    sed -i "/^$pass|/d" "$DB" "$USAGE_DB" 2>/dev/null
    systemctl restart zivpn 2>/dev/null

    # Also remove corresponding UDP Custom user (if exists)
    basepass=$(echo "$pass" | cut -d'_' -f1)
    udp_username="udp_${basepass:0:8}"
    userdel "$udp_username" 2>/dev/null
    echo -e "${GRN}User removed.${RST}"
    read -p "Press Enter to continue..."
}

renew_user() {
    read -p "$(echo -e "${GRN}ZIVPN Password to renew: ${RST}")" pass
    if ! grep -q "^$pass|" "$DB"; then echo -e "${RED}User not found.${RST}"; read -p "Press Enter..."; return; fi
    read -p "$(echo -e "${GRN}Extend by days: ${RST}")" days
    oldexp=$(grep "^$pass|" "$DB" | cut -d'|' -f2)
    newexp=$(date -d "$oldexp +$days days" +%Y-%m-%d 2>/dev/null || echo "$oldexp")
    sed -i "s|^$pass|$oldexp|$pass|$newexp|" "$DB"
    # Renew UDP Custom user
    basepass=$(echo "$pass" | cut -d'_' -f1)
    udp_username="udp_${basepass:0:8}"
    usermod -e "$newexp" "$udp_username" 2>/dev/null
    echo -e "${GRN}Expiry extended to $newexp.${RST}"
    read -p "Press Enter to continue..."
}

cleanup_expired() {
    today=$(date +%Y-%m-%d)
    while IFS='|' read -r pass expiry quota port dev start; do
        if [[ "$expiry" < "$today" ]]; then
            [ -n "$port" ] && remove_tracking "$port"
            jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
            sed -i "/^$pass|/d" "$DB" "$USAGE_DB"
            basepass=$(echo "$pass" | cut -d'_' -f1)
            udp_username="udp_${basepass:0:8}"
            userdel "$udp_username" 2>/dev/null
            echo "Removed expired: $pass"
        fi
    done < "$DB"
    systemctl restart zivpn 2>/dev/null
    echo -e "${GRN}Cleanup completed.${RST}"
    read -p "Press Enter to continue..."
}

list_users() {
    echo -e "\n${CYN}─── ZIVPN Users ───${RST}"
    if [ -s "$DB" ]; then
        column -t -s "|" "$DB"
    else
        echo "No ZIVPN users."
    fi
    echo -e "\n${CYN}─── UDP Custom Users ───${RST}"
    cat /etc/passwd | grep "^udp_" | cut -d: -f1 | while read u; do
        exp=$(chage -l "$u" 2>/dev/null | grep "Account expires" | cut -d: -f2- | xargs)
        echo "$u | Expires: ${exp:-Never}"
    done
    read -p "Press Enter to continue..."
}

show_usage() {
    update_usage_db
    echo -e "\n${CYN}Password | Used / Quota | Port | Expiry${RST}"
    while IFS='|' read -r pass expiry quota port dev start; do
        used=$(grep "^$pass|" "$USAGE_DB" | cut -d'|' -f2)
        used=${used:-0}
        echo "$pass | $(format_bytes $used) / $quota | $port | $expiry"
    done < "$DB"
    read -p "Press Enter to continue..."
}

user_info() {
    read -p "$(echo -e "${GRN}Enter ZIVPN password: ${RST}")" pass
    user_data=$(grep "^$pass|" "$DB")
    [ -z "$user_data" ] && { echo -e "${RED}Not found.${RST}"; read -p "Enter..."; return; }
    IFS='|' read -r p expiry quota port dev start <<< "$user_data"
    used=$(grep "^$pass|" "$USAGE_DB" | cut -d'|' -f2); used=${used:-0}
    quota_bytes=$(quota_to_bytes "$quota")
    remain=$((quota_bytes - used)); [ $remain -lt 0 ] && remain=0
    days_left=$(( ($(date -d "$expiry" +%s) - $(date +%s)) / 86400 ))
    basepass=$(echo "$pass" | cut -d'_' -f1)
    udp_username="udp_${basepass:0:8}"
    echo -e "\n${CYN}User: ${WHT}$pass${RST}"
    echo -e "Expiry: $expiry ($days_left days)"
    echo -e "Quota: $quota | Used: $(format_bytes $used) | Remain: $(format_bytes $remain)"
    echo -e "Device ID: $dev"
    echo -e "UDP Custom user: $udp_username"
    read -p "Press Enter to continue..."
}

trial_user() {
    read -p "Minutes (1-60): " mins
    pass="trial_$(openssl rand -hex 2)"
    add_user_core "$pass" 1 "100MB" "trial" >/dev/null
    echo -e "${GRN}Trial created: $pass (expires in $mins mins)${RST}"
    ( sleep $((mins*60)); /usr/local/bin/onepesewa --bot-removeuser "$pass" ) &
    read -p "Press Enter..."
}

# ------------------ Usage Daemon ------------------
update_usage_db() {
    while IFS='|' read -r pass expiry quota port dev start; do
        [ -z "$port" ] || [ "$port" = "None" ] && continue
        in_bytes=$(iptables -L UDP_IN_$port -v -x 2>/dev/null | grep -oP '\d+' | head -1)
        out_bytes=$(iptables -L UDP_OUT_$port -v -x 2>/dev/null | grep -oP '\d+' | head -1)
        total=$(( ${in_bytes:-0} + ${out_bytes:-0} ))
        grep -v "^$pass|" "$USAGE_DB" > /tmp/usage_tmp
        echo "$pass|$total" >> /tmp/usage_tmp; mv /tmp/usage_tmp "$USAGE_DB"
        quota_bytes=$(quota_to_bytes "$quota")
        if [ $quota_bytes -gt 0 ] && [ $total -ge $quota_bytes ] && ! grep -q "^$pass|.*PAUSED" "$DB"; then
            sed -i "s|^$pass|$pass [PAUSED]|" "$DB"
            jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
            systemctl restart zivpn 2>/dev/null
        fi
    done < "$DB"
}

start_usage_daemon() {
    [ -f "$DAEMON_PID_FILE" ] && kill $(cat "$DAEMON_PID_FILE") 2>/dev/null
    ( while true; do /usr/local/bin/onepesewa --update-usage; sleep 10; done ) &
    echo $! > "$DAEMON_PID_FILE"
}

# ------------------ Bot CLI ------------------
if [[ "$1" == "--bot-"* ]]; then
    cmd="${1#--bot-}"; shift
    case "$cmd" in
        adduser) add_user_core "$1" "$2" "$3" "$4" ;;
        removeuser) pass="$1"; port=$(grep "^$pass|" "$DB" | cut -d'|' -f4); [ -n "$port" ] && remove_tracking "$port"; jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"; sed -i "/^$pass|/d" "$DB" "$USAGE_DB"; systemctl restart zivpn; basepass=$(echo "$pass" | cut -d'_' -f1); userdel "udp_${basepass:0:8}" 2>/dev/null; echo "✅ User removed." ;;
        renew) pass="$1"; days="$2"; oldexp=$(grep "^$pass|" "$DB" | cut -d'|' -f2); newexp=$(date -d "$oldexp +$days days" +%Y-%m-%d); sed -i "s|^$pass|$oldexp|$pass|$newexp|" "$DB"; basepass=$(echo "$pass" | cut -d'_' -f1); usermod -e "$newexp" "udp_${basepass:0:8}" 2>/dev/null; echo "✅ Expiry extended to $newexp" ;;
        cleanup) cleanup_expired >/dev/null; echo "✅ Cleanup done." ;;
        *) echo "Unknown bot command"; exit 1 ;;
    esac
    exit 0
fi


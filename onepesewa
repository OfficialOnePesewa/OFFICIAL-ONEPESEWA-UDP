#!/bin/bash
# OP UDP PANEL – Python Telegram Bot Integration

CONFIG="/etc/zivpn/config.json"
DB="/etc/zivpn/users.db"
USAGE_DB="/etc/zivpn/usage.db"
TELEGRAM_DB="/etc/zivpn/telegram.db"
ADMINS_DB="/etc/zivpn/admins.db"
LAST_SENT_DB="/etc/zivpn/last_sent.db"
CACHE_FILE="/tmp/opudp_geo.cache"
CACHE_TTL=300
PORT_START=6001
PORT_END=19999
DAEMON_PID_FILE="/var/run/opudp_daemon.pid"

RED='\e[1;31m' GRN='\e[1;32m' YLW='\e[1;33m' BLU='\e[1;34m' MAG='\e[1;35m' CYN='\e[1;36m' WHT='\e[1;37m' RST='\e[0m'
BOLD='\e[1m' DIM='\e[2m'

command -v jq &>/dev/null || apt-get install -y jq -qq 2>/dev/null
command -v bc &>/dev/null || apt-get install -y bc -qq 2>/dev/null

# ------------------ Bot CLI Mode ------------------
if [[ "$1" == "--bot-"* ]]; then
    cmd="${1#--bot-}"
    shift
    case "$cmd" in
        status)
            source "$CACHE_FILE" 2>/dev/null || { IP="N/A"; CITY="Unknown"; COUNTRY="Unknown"; ISP="Unknown"; }
            UPTIME=$(uptime -p | sed 's/up //')
            echo "🖥 <b>Server Status</b>%0A🌐 IP: $IP%0A📍 Location: $CITY, $COUNTRY%0A🏢 ISP: $ISP%0A⚡ Service: $(systemctl is-active zivpn)%0A⏱ Uptime: $UPTIME%0A👥 Users: $(jq '.auth.config|length' $CONFIG)"
            ;;
        adduser)
            basepass="$1"; days="$2"; quota="$3"; devid="$4"
            [ -n "$devid" ] && finalpass="${basepass}_${devid}" || { finalpass="$basepass"; devid="None"; }
            exp=$(date -d "+$days days" +%Y-%m-%d)
            port=$(find_free_port)
            [ -z "$port" ] && { echo "ERROR: No free ports"; exit 1; }
            jq --arg p "$finalpass" '.auth.config += [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
            echo "$finalpass|$exp|$quota|$port|$devid|$(date +%Y-%m-%d)" >> "$DB"
            echo "$finalpass|0" >> "$USAGE_DB"
            setup_tracking "$port"
            systemctl restart zivpn 2>/dev/null
            echo "✅ User created:%0A🔑 <code>$finalpass</code>%0A📡 Port: $port%0A📅 Expiry: $exp%0A📊 Quota: $quota"
            ;;
        removeuser)
            pass="$1"
            port=$(grep "^$pass|" "$DB" 2>/dev/null | cut -d'|' -f4)
            [ -n "$port" ] && remove_tracking "$port"
            jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
            sed -i "/^$pass|/d" "$DB" "$USAGE_DB" "$TELEGRAM_DB" "$LAST_SENT_DB" 2>/dev/null
            systemctl restart zivpn 2>/dev/null
            echo "✅ User removed."
            ;;
        renew)
            pass="$1"; days="$2"
            oldexp=$(grep "^$pass|" "$DB" | cut -d'|' -f2)
            [ -z "$oldexp" ] && { echo "ERROR: User not found"; exit 1; }
            newexp=$(date -d "$oldexp +$days days" +%Y-%m-%d)
            sed -i "s|^$pass|$oldexp|$pass|$newexp|" "$DB"
            echo "✅ Expiry extended to $newexp"
            ;;
        resetbw)
            pass="$1"
            port=$(grep "^$pass|" "$DB" | cut -d'|' -f4)
            [ -z "$port" ] && { echo "ERROR: User not found"; exit 1; }
            iptables -Z UDP_IN_$port 2>/dev/null; iptables -Z UDP_OUT_$port 2>/dev/null
            sed -i "s|^$pass|.*|$pass|0|" "$USAGE_DB"
            echo "✅ Bandwidth reset."
            ;;
        userinfo)
            pass="$1"
            user_data=$(grep "^$pass|" "$DB")
            [ -z "$user_data" ] && { echo "ERROR: User not found"; exit 1; }
            IFS='|' read -r p expiry quota port dev start <<< "$user_data"
            used=$(grep "^$pass|" "$USAGE_DB" | cut -d'|' -f2); used=${used:-0}
            quota_bytes=$(quota_to_bytes "$quota")
            remain=$((quota_bytes - used)); [ $remain -lt 0 ] && remain=0
            days_left=$(( ($(date -d "$expiry" +%s) - $(date +%s)) / 86400 ))
            echo "🔍 <b>${pass:0:20}</b>%0A📅 Expiry: $expiry ($days_left days)%0A📊 Quota: $quota%0A📈 Used: $(format_bytes $used)%0A📉 Remain: $(format_bytes $remain)%0A📱 Device: $dev%0A🔌 Port: $port"
            ;;
        cleanup)
            today=$(date +%Y-%m-%d)
            while IFS='|' read -r pass expiry quota port dev start; do
                if [[ "$expiry" < "$today" ]]; then
                    [ -n "$port" ] && remove_tracking "$port"
                    jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
                    sed -i "/^$pass|/d" "$DB" "$USAGE_DB"
                fi
            done < "$DB"
            systemctl restart zivpn 2>/dev/null
            echo "✅ Expired users cleaned."
            ;;
        *) echo "Unknown bot command"; exit 1 ;;
    esac
    exit 0
fi

# ------------------ Helper Functions ------------------
find_free_port() {
    local port=$PORT_START
    while [ $port -le $PORT_END ]; do
        grep -q "|$port|" "$DB" 2>/dev/null || { echo $port; return; }
        port=$((port+1))
    done
    echo ""
}

quota_to_bytes() {
    local q=$(echo "$1" | tr '[:upper:]' '[:lower:]')
    if [[ "$q" =~ ^([0-9.]+)gb$ ]]; then echo "${BASH_REMATCH[1]} * 1073741824" | bc | cut -d. -f1
    elif [[ "$q" =~ ^([0-9.]+)mb$ ]]; then echo "${BASH_REMATCH[1]} * 1048576" | bc | cut -d. -f1
    else echo "0"; fi
}

format_bytes() {
    local b=$1
    if [ $b -ge 1073741824 ]; then echo "$(echo "scale=2; $b/1073741824" | bc) GB"
    elif [ $b -ge 1048576 ]; then echo "$(echo "scale=2; $b/1048576" | bc) MB"
    elif [ $b -ge 1024 ]; then echo "$(echo "scale=2; $b/1024" | bc) KB"
    else echo "$b B"; fi
}

setup_tracking() {
    local port=$1
    iptables -I INPUT -p udp --dport $port -j ACCEPT 2>/dev/null
    iptables -t nat -A PREROUTING -p udp --dport $port -j DNAT --to-destination :5667 2>/dev/null
    iptables -N UDP_IN_$port 2>/dev/null; iptables -N UDP_OUT_$port 2>/dev/null
    iptables -I INPUT -p udp --dport $port -j UDP_IN_$port 2>/dev/null
    iptables -I OUTPUT -p udp --sport $port -j UDP_OUT_$port 2>/dev/null
}

remove_tracking() {
    local port=$1
    iptables -D INPUT -p udp --dport $port -j UDP_IN_$port 2>/dev/null
    iptables -D OUTPUT -p udp --sport $port -j UDP_OUT_$port 2>/dev/null
    iptables -F UDP_IN_$port 2>/dev/null; iptables -X UDP_IN_$port 2>/dev/null
    iptables -F UDP_OUT_$port 2>/dev/null; iptables -X UDP_OUT_$port 2>/dev/null
    iptables -D INPUT -p udp --dport $port -j ACCEPT 2>/dev/null
    iptables -t nat -D PREROUTING -p udp --dport $port -j DNAT --to-destination :5667 2>/dev/null
}

fetch_geo() {
    if [ -f "$CACHE_FILE" ] && [ $(($(date +%s) - $(stat -c %Y "$CACHE_FILE" 2>/dev/null || echo 0))) -lt $CACHE_TTL ]; then
        return
    fi
    GEO=$(curl -4 -s --max-time 5 https://ipapi.co/json/ 2>/dev/null)
    if [ -n "$GEO" ] && echo "$GEO" | grep -q '"ip"'; then
        IP=$(echo "$GEO" | grep -oP '"ip":\s*"\K[^"]+')
        CITY=$(echo "$GEO" | grep -oP '"city":\s*"\K[^"]+')
        COUNTRY=$(echo "$GEO" | grep -oP '"country_name":\s*"\K[^"]+')
        ISP=$(echo "$GEO" | grep -oP '"org":\s*"\K[^"]+')
    else
        IP="N/A"; CITY="Unknown"; COUNTRY="Unknown"; ISP="Unknown"
    fi
    echo "IP=\"$IP\"; CITY=\"$CITY\"; COUNTRY=\"$COUNTRY\"; ISP=\"$ISP\"" > "$CACHE_FILE"
}

update_usage_db() {
    while IFS='|' read -r pass expiry quota port dev start; do
        [ -z "$port" ] || [ "$port" = "None" ] && continue
        in_bytes=$(iptables -L UDP_IN_$port -v -x 2>/dev/null | grep -oP '\d+' | head -1)
        out_bytes=$(iptables -L UDP_OUT_$port -v -x 2>/dev/null | grep -oP '\d+' | head -1)
        total=$(( ${in_bytes:-0} + ${out_bytes:-0} ))
        prev=$(grep "^$pass|" "$USAGE_DB" 2>/dev/null | cut -d'|' -f2); prev=${prev:-0}
        grep -v "^$pass|" "$USAGE_DB" > /tmp/usage_tmp
        echo "$pass|$total" >> /tmp/usage_tmp; mv /tmp/usage_tmp "$USAGE_DB"

        # Notification
        last_sent=$(grep "^$pass|" "$LAST_SENT_DB" 2>/dev/null | cut -d'|' -f2)
        if [ $total -gt $prev ] && [ $((total - prev)) -gt 1024 ] && ([ -z "$last_sent" ] || [ $(($(date +%s) - last_sent)) -gt 3600 ]); then
            grep -v "^$pass|" "$LAST_SENT_DB" > /tmp/last_tmp
            echo "$pass|$(date +%s)" >> /tmp/last_tmp; mv /tmp/last_tmp "$LAST_SENT_DB"
        fi

        # Quota enforcement
        quota_bytes=$(quota_to_bytes "$quota")
        if [ $quota_bytes -gt 0 ] && [ $total -ge $quota_bytes ] && ! grep -q "^$pass|.*PAUSED" "$DB"; then
            sed -i "s|^$pass|$pass [PAUSED]|" "$DB"
            jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
            systemctl restart zivpn 2>/dev/null
        fi
    done < "$DB"
}

start_usage_daemon() {
    [ -f "$DAEMON_PID_FILE" ] && kill $(cat "$DAEMON_PID_FILE") 2>/dev/null
    ( while true; do /usr/local/bin/onepesewa --update-usage; sleep 10; done ) &
    echo $! > "$DAEMON_PID_FILE"
}

stop_daemons() {
    [ -f "$DAEMON_PID_FILE" ] && kill $(cat "$DAEMON_PID_FILE") 2>/dev/null && rm -f "$DAEMON_PID_FILE"
    systemctl stop opudp-bot 2>/dev/null
}

telegram_setup() {
    read -p "Bot Token: " token
    echo "$token" > /etc/zivpn/telegram_token
    chmod 600 /etc/zivpn/telegram_token
    systemctl enable opudp-bot
    systemctl restart opudp-bot
    echo -e "${GRN}Token saved. Bot started.${RST}"
    read -p "Press Enter..."
}

# ------------------ Main Menu ------------------
if [ "$1" = "--update-usage" ]; then update_usage_db; exit 0; fi

fetch_geo
start_usage_daemon

while true; do
    clear
    echo -e "${WHT}${BOLD}OP UDP PANEL${RST}"
    echo "1) Start        2) Stop         3) Restart      4) Status       5) List"
    echo "6) Add User     7) Remove       8) Renew        9) Cleanup      10) Usage Stats"
    echo "11) Reset BW    12) Speed Test  13) Live Logs   14) Backup      15) Restore"
    echo "16) Port Range  17) Update      18) Conn Limit  19) Trial User  20) User Info"
    echo "21) TG Setup    22) Add Admin   23) List Admins"
    echo "99) UNINSTALL   0) Exit"
    read -p "Choose: " opt
    case $opt in
        1) systemctl start zivpn; read -p "Enter...";;
        2) systemctl stop zivpn; read -p "Enter...";;
        3) systemctl restart zivpn; read -p "Enter...";;
        4) systemctl status zivpn; read -p "Enter...";;
        5) column -t -s "|" "$DB"; read -p "Enter...";;
        6) read -p "BasePass: " bp; read -p "Days: " d; read -p "Quota: " q; read -p "DevID: " dev; /usr/local/bin/onepesewa --bot-adduser "$bp" "$d" "$q" "$dev"; read -p "Enter...";;
        7) read -p "Password: " p; /usr/local/bin/onepesewa --bot-removeuser "$p"; read -p "Enter...";;
        8) read -p "Password: " p; read -p "Days: " d; /usr/local/bin/onepesewa --bot-renew "$p" "$d"; read -p "Enter...";;
        9) /usr/local/bin/onepesewa --bot-cleanup; read -p "Enter...";;
        10) update_usage_db; cat "$USAGE_DB"; read -p "Enter...";;
        11) read -p "Password: " p; /usr/local/bin/onepesewa --bot-resetbw "$p"; read -p "Enter...";;
        12) speedtest-cli --simple 2>/dev/null || echo "Install speedtest-cli"; read -p "Enter...";;
        13) journalctl -u zivpn -f;;
        14) mkdir -p /root/opudp_backup; tar -czf /root/opudp_backup/opudp_$(date +%Y%m%d).tar.gz /etc/zivpn; echo "Backup done."; read -p "Enter...";;
        15) ls /root/opudp_backup/*.tar.gz; read -p "File: " f; [ -f "$f" ] && { systemctl stop zivpn; tar -xzf "$f" -C /; systemctl start zivpn; echo "Restored."; }; read -p "Enter...";;
        16) read -p "Start: " s; read -p "End: " e; PORT_START=$s; PORT_END=$e; echo "Updated."; read -p "Enter...";;
        17) wget -qO /usr/local/bin/onepesewa https://raw.githubusercontent.com/OfficialOnePesewa/OFFICIAL-ONEPESEWA-UDP/main/onepesewa && chmod +x /usr/local/bin/onepesewa && wget -qO /usr/local/bin/opudp_bot.py https://raw.githubusercontent.com/OfficialOnePesewa/OFFICIAL-ONEPESEWA-UDP/main/opudp_bot.py && systemctl restart opudp-bot && echo "Updated."; sleep 2; exec onepesewa;;
        18) read -p "Limit: " l; echo "$l" > /etc/zivpn/conn_limit; echo "Set."; read -p "Enter...";;
        19) read -p "Minutes: " m; pass="trial_$(openssl rand -hex 2)"; /usr/local/bin/onepesewa --bot-adduser "$pass" 1 "100MB" "trial" >/dev/null; echo "Trial: $pass"; (sleep $((m*60)); /usr/local/bin/onepesewa --bot-removeuser "$pass") & read -p "Enter...";;
        20) read -p "Password: " p; /usr/local/bin/onepesewa --bot-userinfo "$p"; read -p "Enter...";;
        21) telegram_setup;;
        22) read -p "Chat ID: " id; read -p "Name: " n; echo "$id|admin|$n" >> "$ADMINS_DB"; read -p "Enter...";;
        23) cat "$ADMINS_DB"; read -p "Enter...";;
        99) systemctl stop zivpn; stop_daemons; rm -rf /etc/zivpn /usr/local/bin/zivpn /usr/local/bin/onepesewa /usr/local/bin/opudp_bot.py /etc/systemd/system/opudp-bot.service; echo "Uninstalled."; exit;;
        0) stop_daemons; exit;;
        *) echo "Invalid"; read -p "Enter...";;
    esac
done

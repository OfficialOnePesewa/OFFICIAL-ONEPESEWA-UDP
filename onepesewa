#!/bin/bash

# =========================================
# ONEPESEWA UDP PANEL (FULL FINAL VERSION)
# =========================================

# Safe execution (prevents crashes)
set -eo pipefail

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Database file
DB="/etc/onepesewa-users.db"

# Ensure DB exists
[ ! -f "$DB" ] && touch "$DB"

# =========================================
# MAIN MENU
# =========================================
menu() {
clear
echo -e "${GREEN}====================================${NC}"
echo -e "${GREEN}        ONEPESEWA UDP PANEL         ${NC}"
echo -e "${GREEN}====================================${NC}"
echo ""
echo "1. Install UDP Server"
echo "2. Start UDP Service"
echo "3. Stop UDP Service"
echo "4. Restart UDP Service"
echo "5. Check UDP Status"
echo "6. User Manager"
echo "7. View Logs"
echo "8. Exit"
echo ""
read -p "Select option: " opt

case "$opt" in
1) install_udp ;;
2) start_udp ;;
3) stop_udp ;;
4) restart_udp ;;
5) status_udp ;;
6) user_manager ;;
7) view_logs ;;
8) exit 0 ;;
*) echo -e "${RED}Invalid option${NC}"; sleep 1; menu ;;
esac
}

# =========================================
# UDP FUNCTIONS
# =========================================

install_udp() {
echo -e "${YELLOW}Installing UDP Custom...${NC}"
apt update -y
apt install -y git wget curl

cd /root || exit 1
rm -rf udp-custom

git clone https://github.com/http-custom/udp-custom.git
cd udp-custom || exit 1

chmod +x install.sh
./install.sh

echo -e "${GREEN}Installation complete!${NC}"
sleep 2
menu
}

start_udp() {
systemctl start udp-custom 2>/dev/null
if [ $? -eq 0 ]; then
    echo -e "${GREEN}UDP Service Started${NC}"
else
    echo -e "${RED}Failed to start service${NC}"
fi
sleep 1
menu
}

stop_udp() {
systemctl stop udp-custom 2>/dev/null
if [ $? -eq 0 ]; then
    echo -e "${RED}UDP Service Stopped${NC}"
else
    echo -e "${RED}Failed to stop service${NC}"
fi
sleep 1
menu
}

restart_udp() {
systemctl restart udp-custom 2>/dev/null
if [ $? -eq 0 ]; then
    echo -e "${YELLOW}UDP Service Restarted${NC}"
else
    echo -e "${RED}Failed to restart service${NC}"
fi
sleep 1
menu
}

status_udp() {
systemctl status udp-custom --no-pager
echo ""
read -p "Press enter to go back..."
menu
}

view_logs() {
journalctl -u udp-custom --no-pager -n 50
echo ""
read -p "Press enter to go back..."
menu
}

# =========================================
# USER MANAGER
# =========================================

user_manager() {
clear
echo "=========== USER MANAGER ==========="
echo "1. Add User"
echo "2. Delete User"
echo "3. List Users"
echo "4. Back"
echo ""
read -p "Select option: " uopt

case "$uopt" in
1) add_user ;;
2) del_user ;;
3) list_user ;;
4) menu ;;
*) echo "Invalid option"; sleep 1; user_manager ;;
esac
}

add_user() {
read -p "Enter Username: " user
read -p "Enter Password: " pass

if [ -z "$user" ] || [ -z "$pass" ]; then
    echo -e "${RED}Username or password cannot be empty${NC}"
elif grep -q "^$user:" "$DB"; then
    echo -e "${RED}User already exists${NC}"
else
    echo "$user:$pass" >> "$DB"
    echo -e "${GREEN}User added successfully${NC}"
fi

sleep 1
user_manager
}

del_user() {
read -p "Enter Username to delete: " user

if grep -q "^$user:" "$DB"; then
    sed -i "/^$user:/d" "$DB"
    echo -e "${GREEN}User deleted${NC}"
else
    echo -e "${RED}User not found${NC}"
fi

sleep 1
user_manager
}

list_user() {
echo "=========== USER LIST ==========="

if [ -s "$DB" ]; then
    cat "$DB"
else
    echo "No users found"
fi

echo ""
read -p "Press enter to go back..."
user_manager
}

# =========================================
# ENTRY POINT
# =========================================

case "${1:-menu}" in
menu) menu ;;
install) install_udp ;;
start) start_udp ;;
stop) stop_udp ;;
restart) restart_udp ;;
status) status_udp ;;
users) user_manager ;;
*)
echo "Usage: onepesewa {menu|install|start|stop|restart|status|users}"
;;
esac

find_free_port() {
    local port=6001
    while [ $port -le 19999 ]; do
        grep -q "|$port|" "$DB" 2>/dev/null || { echo $port; return; }
        port=$((port+1))
    done
    echo ""
}

add_user() {
    echo -e "\n${YLW}╭────────────────── CREATE ZIVPN USER ──────────────────╮${RST}"
    read -p "$(echo -e "${GRN}Base Password  : ${RST}")" basepass
    read -p "$(echo -e "${GRN}Validity (Days): ${RST}")" days
    read -p "$(echo -e "${GRN}Quota (GB/MB)  : ${RST}")" quota
    read -p "$(echo -e "${GRN}Device ID      : ${RST}")" devid
    echo -e "${YLW}╰──────────────────────────────────────────────────────╯${RST}"

    if [ -z "$devid" ]; then
        echo -e "${RED}Device ID is required for binding!${RST}"
        read -p "Press Enter to continue..."
        return
    fi

    finalpass="${basepass}_${devid}"
    exp=$(date -d "+$days days" +%Y-%m-%d)
    port=$(find_free_port)
    
    # Add to ZIVPN config
    jq --arg p "$finalpass" '.auth.config += [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
    echo "$finalpass|$exp|$quota|$port|$devid|$(date +%Y-%m-%d)" >> "$DB"
    echo "$finalpass|0" >> "$USAGE_DB"
    
    # Add device binding
    jq --arg pass "$finalpass" --arg dev "$devid" '. + {($pass): {"password": $pass, "device_id": $dev}}' "$BINDINGS" > /tmp/bindings_tmp && mv /tmp/bindings_tmp "$BINDINGS"
    
    systemctl restart zivpn zivpn-proxy --no-block 2>/dev/null &
    fetch_geo
    
    echo -e "\n${CYN}╭──────────────────────────────────────────────────────╮${RST}"
    echo -e "${CYN}│  ${GRN}🎉 ZIVPN USER CREATED (Device Bound) 🎉${RST}${CYN}            │${RST}"
    echo -e "${CYN}│${RST} ${YLW}🔑 Password :${RST} ${WHT}$finalpass${RST}"
    echo -e "${CYN}│${RST} ${YLW}📋 Connection:${RST}"
    echo -e "${CYN}│${RST}    ${WHT}Server IP: $IP${RST}"
    echo -e "${CYN}│${RST}    ${WHT}Port: 5667${RST}"
    echo -e "${CYN}│${RST}    ${WHT}Password: $finalpass${RST}"
    echo -e "${CYN}│${RST} ${YLW}📱 Device ID :${RST} ${WHT}$devid${RST}"
    echo -e "${CYN}│${RST} ${YLW}⏳ Expiry    :${RST} ${WHT}$exp ($days days)${RST}"
    echo -e "${CYN}│${RST} ${YLW}📊 Quota     :${RST} ${WHT}$quota${RST}"
    echo -e "${CYN}├──────────────────────────────────────────────────────┤${RST}"
    echo -e "${CYN}│${RST} ${MAG}🌍 Server   :${RST} ${WHT}$CITY, $COUNTRY${RST}"
    echo -e "${CYN}│${RST} ${MAG}🏢 ISP      :${RST} ${WHT}$ISP${RST}"
    echo -e "${CYN}│${RST} ${MAG}📱 Admin TG :${RST} ${WHT}$ADMIN_TELEGRAM${RST}"
    echo -e "${CYN}│${RST} ${YLW}$DONATION_MSG${RST}               ${CYN}│${RST}"
    echo -e "${CYN}╰──────────────────────────────────────────────────────╯${RST}\n"
    read -p "Press Enter to continue..."
}

remove_user() {
    read -p "$(echo -e "${GRN}Password to remove: ${RST}")" pass
    jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
    jq "del(.\"$pass\")" "$BINDINGS" > /tmp/bindings_tmp && mv /tmp/bindings_tmp "$BINDINGS"
    sed -i "/^$pass|/d" "$DB" "$USAGE_DB"
    systemctl restart zivpn zivpn-proxy --no-block 2>/dev/null &
    echo -e "${GRN}User removed.${RST}"
    read -p "Press Enter to continue..."
}

renew_user() {
    read -p "$(echo -e "${GRN}Password: ${RST}")" pass
    read -p "$(echo -e "${GRN}Extend by days: ${RST}")" days
    oldexp=$(grep "^$pass|" "$DB" | cut -d'|' -f2)
    newexp=$(date -d "$oldexp +$days days" +%Y-%m-%d)
    sed -i "s|^$pass|$oldexp|$pass|$newexp|" "$DB"
    echo -e "${GRN}Expiry extended to $newexp.${RST}"
    read -p "Press Enter to continue..."
}

cleanup_expired() {
    today=$(date +%Y-%m-%d)
    while IFS='|' read -r p exp q port dev start; do
        if [[ "$exp" < "$today" ]]; then
            jq --arg p "$p" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
            jq "del(.\"$p\")" "$BINDINGS" > /tmp/bindings_tmp && mv /tmp/bindings_tmp "$BINDINGS"
            sed -i "/^$p|/d" "$DB" "$USAGE_DB"
            echo "Removed expired: $p"
        fi
    done < "$DB"
    systemctl restart zivpn zivpn-proxy --no-block 2>/dev/null &
    echo -e "${GRN}Cleanup completed.${RST}"
    read -p "Press Enter to continue..."
}

show_usage() {
    echo -e "\n${CYN}ZIVPN Usage:${RST}"
    while IFS='|' read -r p exp q port dev start; do
        used=$(grep "^$p|" "$USAGE_DB" | cut -d'|' -f2)
        echo "$p | Used: ${used:-0} | Quota: $q | Expiry: $exp"
    done < "$DB"
    read -p "Press Enter to continue..."
}

service_control() {
    action=$1
    echo -e "${YLW}Select: 1) ZIVPN only  2) Proxy only  3) Both${RST}"
    read -p "Choice: " svc
    case $svc in
        1) systemctl $action zivpn --no-block & ;;
        2) systemctl $action zivpn-proxy --no-block & ;;
        3) systemctl $action zivpn --no-block & systemctl $action zivpn-proxy --no-block & ;;
        *) echo "Invalid";;
    esac
    echo -e "${GRN}Command sent.${RST}"
}

vps_optimizer() {
    if [ -f /usr/local/bin/optimize.sh ]; then
        bash /usr/local/bin/optimize.sh
    else
        echo -e "${RED}Optimizer not found.${RST}"
    fi
    read -p "Press Enter to continue..."
}

# Bot CLI mode
if [[ "$1" == "--bot-"* ]]; then
    cmd="${1#--bot-}"

#!/bin/bash
# OP UDP PANEL – Dual Protocol (ZIVPN + UDP Custom) with Device Binding
# One unified panel for both ZIVPN and HTTP Custom UDP tunneling

CONFIG="/etc/zivpn/config.json"
DB="/etc/zivpn/users.db"
USAGE_DB="/etc/zivpn/usage.db"
TELEGRAM_DB="/etc/zivpn/telegram.db"
ADMINS_DB="/etc/zivpn/admins.db"
LAST_SENT_DB="/etc/zivpn/last_sent.db"
CACHE_FILE="/tmp/opudp_geo.cache"
CACHE_TTL=300
PORT_START=6001
PORT_END=19999
DAEMON_PID_FILE="/var/run/opudp_daemon.pid"

# Colors
RED='\e[1;31m' GRN='\e[1;32m' YLW='\e[1;33m' BLU='\e[1;34m' MAG='\e[1;35m' CYN='\e[1;36m' WHT='\e[1;37m' RST='\e[0m'
BOLD='\e[1m' DIM='\e[2m'

# Dependencies
command -v jq &>/dev/null || apt-get install -y jq -qq 2>/dev/null
command -v bc &>/dev/null || apt-get install -y bc -qq 2>/dev/null
command -v speedtest-cli &>/dev/null || apt-get install -y speedtest-cli -qq 2>/dev/null

# ------------------ Geo Fetch (ipapi.co) ------------------
fetch_geo() {
    if [ -f "$CACHE_FILE" ] && [ $(($(date +%s) - $(stat -c %Y "$CACHE_FILE" 2>/dev/null || echo 0))) -lt $CACHE_TTL ]; then
        source "$CACHE_FILE"
        return
    fi
    printf "${DIM}Fetching location...${RST}"
    GEO=$(curl -4 -s --max-time 8 https://ipapi.co/json/ 2>/dev/null)
    if [ -z "$GEO" ] || ! echo "$GEO" | grep -q '"ip"'; then
        IP="N/A"; CITY="Unknown"; COUNTRY="Unknown"; ISP="Unknown"; COUNTRY_CODE=""
    else
        IP=$(echo "$GEO" | grep -oP '"ip":\s*"\K[^"]+')
        CITY=$(echo "$GEO" | grep -oP '"city":\s*"\K[^"]+')
        COUNTRY=$(echo "$GEO" | grep -oP '"country_name":\s*"\K[^"]+')
        COUNTRY_CODE=$(echo "$GEO" | grep -oP '"country_code":\s*"\K[^"]+' | tr '[:upper:]' '[:lower:]')
        ISP=$(echo "$GEO" | grep -oP '"org":\s*"\K[^"]+')
    fi
    echo "IP=\"$IP\"; CITY=\"$CITY\"; COUNTRY=\"$COUNTRY\"; COUNTRY_CODE=\"$COUNTRY_CODE\"; ISP=\"$ISP\"" > "$CACHE_FILE"
    printf "\r\033[K"
}

flag() {
    case $1 in
        us) echo "🇺🇸" ;; gb) echo "🇬🇧" ;; ca) echo "🇨🇦" ;; au) echo "🇦🇺" ;;
        de) echo "🇩🇪" ;; fr) echo "🇫🇷" ;; nl) echo "🇳🇱" ;; in) echo "🇮🇳" ;;
        jp) echo "🇯🇵" ;; br) echo "🇧🇷" ;; za) echo "🇿🇦" ;; sg) echo "🇸🇬" ;;
        gh) echo "🇬🇭" ;; ng) echo "🇳🇬" ;; ke) echo "🇰🇪" ;; il) echo "🇮🇱" ;;
        *) echo "" ;;
    esac
}

get_sysinfo() {
    OS_INFO=$(grep PRETTY_NAME /etc/os-release | cut -d'"' -f2)
    KERNEL=$(uname -r)
    ARCH=$(uname -m)
    OS_FULL="$OS_INFO $ARCH"
    UPTIME=$(uptime -p | sed 's/up //; s/ days/d/; s/ day/d/; s/ hours/h/; s/ hour/h/; s/ minutes/m/; s/ minute/m/')
    [ -z "$UPTIME" ] && UPTIME="N/A"
    if systemctl is-active --quiet zivpn; then
        ZSTATUS="${GRN}🟢 active${RST}"
    else
        ZSTATUS="${RED}🔴 inactive${RST}"
    fi
    if systemctl is-active --quiet udp-custom; then
        USTATUS="${GRN}🟢 active${RST}"
    else
        USTATUS="${RED}🔴 inactive${RST}"
    fi
    ZUSER_COUNT=$(jq '.auth.config | length' "$CONFIG" 2>/dev/null || echo "0")
    UUSER_COUNT=$(cat /etc/passwd 2>/dev/null | grep -c "^udp_" || echo "0")
    DATE_TIME=$(TZ="Africa/Accra" date +"%A, %d %B %Y  %I:%M:%S %p %Z")
    FLAG=$(flag "$COUNTRY_CODE")
    [ -n "$FLAG" ] && LOC_STR="${FLAG}  $CITY, $COUNTRY" || LOC_STR="$CITY, $COUNTRY"
}


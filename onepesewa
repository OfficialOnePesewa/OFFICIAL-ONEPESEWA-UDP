# --- Add User (with card) ---
add_user() {
    echo -e "\n${YLW}в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ CREATE NEW USER в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ${RST}"
    read -p "$(echo -e ${GRN}User Password:${RST} )" pass
    read -p "$(echo -e ${GRN}Validity (Days):${RST} )" days
    read -p "$(echo -e ${GRN}Quota (GB/MB):${RST} )" quota
    read -p "$(echo -e ${GRN}Device ID (Optional):${RST} )" devid

    exp=$(date -d "+$days days" +%Y-%m-%d)

    if [ -f "$CONFIG" ]; then

# Menu functions (frontend)
add_user() { read -p "Base Password: " bp; read -p "Days: " d; read -p "Quota: " q; read -p "Device ID: " dev; add_user_core "$bp" "$d" "$q" "$dev" | while IFS='|' read s fp exp port quota; do echo -e "${GRN}Created: $fp${RST}"; done; read -p "Enter..."; }
remove_user() { read -p "Password: " p; remove_user_core "$p"; echo -e "${GRN}Removed.${RST}"; read -p "Enter..."; }
renew_user() { read -p "Password: " p; read -p "Days: " d; renew_user_core "$p" "$d"; echo -e "${GRN}Renewed.${RST}"; read -p "Enter..."; }
cleanup_expired() { cleanup_expired_core; echo -e "${GRN}Cleaned.${RST}"; read -p "Enter..."; }
show_usage_stats() {
    update_usage_db
    echo -e "\n${CYN}Password | Used/Quota | Port | Expiry${RST}"
    while IFS='|' read -r pass expiry quota port dev start; do
        used=$(grep "^$pass|" "$USAGE_DB" | cut -d'|' -f2); used=${used:-0}
        used_fmt=$(format_bytes $used)
        quota_bytes=$(quota_to_bytes "$quota")
        [ $quota_bytes -gt 0 ] && [ $used -ge $quota_bytes ] && st="${RED}PAUSED${RST}" || st="${GRN}ACTIVE${RST}"
        echo "$pass | $used_fmt / $quota | $port | $expiry $st"
    done < "$DB"
    read -p "Enter..."
}
reset_bandwidth() { read -p "Password: " p; reset_bw_core "$p"; echo -e "${GRN}Reset.${RST}"; read -p "Enter..."; }
speed_test() { speedtest-cli --simple; read -p "Enter..."; }
backup_data() { mkdir -p /root/opudp_backup; tar -czf /root/opudp_backup/opudp_$(date +%Y%m%d).tar.gz /etc/zivpn; echo -e "${GRN}Backup done.${RST}"; read -p "Enter..."; }
restore_backup() { ls /root/opudp_backup/*.tar.gz; read -p "File: " f; [ -f "$f" ] && { systemctl stop zivpn; tar -xzf "$f" -C /; systemctl start zivpn; echo "Restored."; }; read -p "Enter..."; }
change_port_range() { read -p "Start: " s; read -p "End: " e; PORT_START=$s; PORT_END=$e; echo "Updated."; read -p "Enter..."; }
set_conn_limit() { read -p "Limit: " l; echo "$l" > /etc/zivpn/conn_limit; echo "Set."; read -p "Enter..."; }
trial_user() { read -p "Minutes: " m; pass="trial_$(openssl rand -hex 2)"; add_user_core "$pass" 1 "100MB" "trial" >/dev/null; echo "Trial: $pass"; (sleep $((m*60)); remove_user_core "$pass") & read -p "Enter..."; }
user_info() { read -p "Password: " p; get_user_info "$p" | while IFS='|' read s pass exp q used remain days dev port start; do clear; echo -e "User: $pass\nExpiry: $exp ($days days)\nQuota: $q\nUsed: $used\nRemain: $remain\nDevice: $dev\nPort: $port"; done; read -p "Enter..."; }

# Main loop
while true; do
    banner; show_menu
    read -p "Choose: " opt
    case $opt in
        1) systemctl start zivpn; echo "Started"; read -p "Enter..."; ;;
        2) systemctl stop zivpn; echo "Stopped"; read -p "Enter..."; ;;
        3) systemctl restart zivpn; echo "Restarted"; read -p "Enter..."; ;;
        4) systemctl status zivpn; read -p "Enter..."; ;;
        5) column -t -s "|" "$DB"; read -p "Enter..."; ;;
        6) add_user ;;
        7) remove_user ;;
        8) renew_user ;;
        9) cleanup_expired ;;
        10) show_usage_stats ;;
        11) show_usage_stats ;;
        12) reset_bandwidth ;;
        13) speed_test ;;
        14) journalctl -u zivpn -f ;;
        15) backup_data ;;
        16) restore_backup ;;
        17) change_port_range ;;
        18) wget -qO /usr/local/bin/onepesewa https://raw.githubusercontent.com/OfficialOnePesewa/OFFICIAL-ONEPESEWA-UDP/main/onepesewa && chmod +x /usr/local/bin/onepesewa && echo "Updated. Restarting..."; sleep 2; exec onepesewa ;;
        19) set_conn_limit ;;

# --- Main Loop ---
while true; do
    banner
    show_menu
    read -p "$(echo -e ${CYN}Choose [0-99]:${RST} )" opt

    case $opt in
        1) systemctl start zivpn && echo -e "${GRN}Started.${RST}" || echo -e "${RED}Failed.${RST}" ;;
        2) systemctl stop zivpn && echo -e "${RED}Stopped.${RST}" || echo -e "${RED}Failed.${RST}" ;;
        3) systemctl restart zivpn && echo -e "${GRN}Restarted.${RST}" || echo -e "${RED}Failed.${RST}" ;;
        4) systemctl status zivpn ;;
        5)
           if [ -f "$DB" ]; then
               echo -e "\n${CYN}Pass | Expiry | Quota | DeviceID${RST}"
               echo "---------------------------------"
               column -t -s "|" "$DB"
           else
               echo -e "${RED}No user database.${RST}"
           fi
           read -p "Press Enter to continue..."
           ;;
        6) add_user ;;
        7)
           read -p "$(echo -e ${GRN}Password to remove:${RST} )" pass
           if [ -f "$CONFIG" ]; then
               jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
           fi
           [ -f "$DB" ] && sed -i "/^$pass|/d" "$DB"
           systemctl restart zivpn 2>/dev/null
           echo -e "${GRN}User removed.${RST}"
           read -p "Press Enter to continue..."
           ;;
        8) echo "Function not implemented yet."; read -p "Press Enter..." ;;
        9) echo "Function not implemented yet."; read -p "Press Enter..." ;;
        10) echo "Function not implemented yet."; read -p "Press Enter..." ;;
        11) echo "Function not implemented yet."; read -p "Press Enter..." ;;
        12) echo "Function not implemented yet."; read -p "Press Enter..." ;;
        13) echo "Function not implemented yet."; read -p "Press Enter..." ;;
        14) journalctl -u zivpn -f ;;
        15) echo "Function not implemented yet."; read -p "Press Enter..." ;;
        16) echo "Function not implemented yet."; read -p "Press Enter..." ;;
        17) echo "Function not implemented yet."; read -p "Press Enter..." ;;
        18)
           echo -e "\n${YLW}Fetching latest panel from GitHub...${RST}"
           wget -qO /usr/local/bin/onepesewa https://raw.githubusercontent.com/OfficialOnePesewa/OFFICIAL-ONEPESEWA-UDP/main/onepesewa
           chmod +x /usr/local/bin/onepesewa
           echo -e "${GRN}Update complete! Restarting...${RST}"
           sleep 2
           exec onepesewa
           ;;
        19) echo "Function not implemented yet."; read -p "Press Enter..." ;;
        20) trial_user ;;
        99)
           systemctl stop zivpn 2>/dev/null
           rm -rf /etc/zivpn /usr/local/bin/zivpn /usr/local/bin/onepesewa
           echo -e "${RED}Uninstalled.${RST}"
           exit
           ;;
        0) goodbye; exit ;;
        *) echo -e "${RED}Invalid option.${RST}"; read -p "Press Enter..." ;;
    esac
done

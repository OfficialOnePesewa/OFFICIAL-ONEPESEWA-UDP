            sed -i "/^$pass|/d" "$DB" "$USAGE_DB"
            systemctl restart zivpn zivpn-proxy --no-block 2>/dev/null &
            echo "✅ User removed."
            ;;
        renew) pass="$1"; days="$2"
            oldexp=$(grep "^$pass|" "$DB" | cut -d'|' -f2)
            newexp=$(date -d "$oldexp +$days days" +%Y-%m-%d)
            sed -i "s|^$pass|$oldexp|$pass|$newexp|" "$DB"
            echo "✅ Expiry extended to $newexp"
            ;;
        cleanup) today=$(date +%Y-%m-%d)
            while IFS='|' read -r p exp q port dev start; do
                [[ "$exp" < "$today" ]] && jq --arg p "$p" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG" && jq "del(.\"$p\")" "$BINDINGS" > /tmp/bindings_tmp && mv /tmp/bindings_tmp "$BINDINGS" && sed -i "/^$p|/d" "$DB" "$USAGE_DB"
            done < "$DB"
            systemctl restart zivpn zivpn-proxy --no-block 2>/dev/null &
            echo "✅ Cleanup done."
            ;;
        *) echo "Unknown bot command"; exit 1 ;;
    esac
    exit 0
fi

fetch_geo

while true; do

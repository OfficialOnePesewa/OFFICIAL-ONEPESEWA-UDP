fetch_geo() {
    if [ -f "$CACHE_FILE" ] && [ $(( $(date +%s) - $(stat -c %Y "$CACHE_FILE" 2>/dev/null || echo 0) )) -lt $CACHE_TTL ]; then
        source "$CACHE_FILE"; return
    fi
    GEO=""
    for api in "https://ipapi.co/json/" "https://ip-api.com/json/?fields=status,message,country,countryCode,city,zip,isp,query" "https://ipinfo.io/json"; do
        GEO=$(curl -4 -s --max-time 6 "$api" 2>/dev/null)
        [ -z "\( GEO" ] && GEO= \)(wget -q -O- --timeout=6 "$api" 2>/dev/null)
        [ -n "$GEO" ] && echo "$GEO" | grep -qE '"ip"|"query"' && break
        GEO=""
    done
    if [ -z "$GEO" ]; then
        IP="N/A"; CITY="Unknown"; COUNTRY="Unknown"; COUNTRY_CODE=""; ZIP=""; ISP="Unknown"
    else
        IP=$(echo "$GEO" | grep -oP '"(?:ip|query)":\s*"\K[^"]+' | head -1)
        CITY=$(echo "$GEO" | grep -oP '"city":\s*"\K[^"]+')
        COUNTRY=$(echo "$GEO" | grep -oP '"(?:country_name|country)":\s*"\K[^"]+' | head -1)
        COUNTRY_CODE=$(echo "$GEO" | grep -oP '"countryCode":\s*"\K[A-Z]{2}' | head -1 | tr '[:upper:]' '[:lower:]')
        ZIP=$(echo "$GEO" | grep -oP '"(?:postal|zip)":\s*"\K[^"]+')
        ISP=$(echo "$GEO" | grep -oP '"(?:org|isp)":\s*"\K[^"]+' | head -1)
    fi
    printf 'IP="%s"; CITY="%s"; COUNTRY="%s"; COUNTRY_CODE="%s"; ZIP="%s"; ISP="%s"\n' "$IP" "$CITY" "$COUNTRY" "$COUNTRY_CODE" "$ZIP" "$ISP" > "$CACHE_FILE"
}

flag() {
    case $1 in
        us)echo "🇺🇸";;gb)echo "🇬🇧";;ca)echo "🇨🇦";;au)echo "🇦🇺";;
        de)echo "🇩🇪";;fr)echo "🇫🇷";;nl)echo "🇳🇱";;in)echo "🇮🇳";;
        jp)echo "🇯🇵";;br)echo "🇧🇷";;za)echo "🇿🇦";;sg)echo "🇸🇬";;
        gh)echo "🇬🇭";;ng)echo "🇳🇬";;ke)echo "🇰🇪";;*) echo "🌐";;
    esac
}

get_sysinfo() {
    OS_INFO=$(grep PRETTY_NAME /etc/os-release 2>/dev/null | cut -d'"' -f2 || uname -o)
    UPTIME=$(uptime -p 2>/dev/null | sed 's/up //;s/ days\?/d/;s/ hours\?/h/;s/ minutes\?/m/' || echo "N/A")
    KERNEL=$(uname -r)
    MEM_TOTAL=$(free -m 2>/dev/null | awk '/Mem:/{print $2}')
    MEM_USED=$(free -m 2>/dev/null | awk '/Mem:/{print $3}')
    LOAD=$(uptime | awk -F'load average:' '{print $2}' | xargs 2>/dev/null)
    DISK_USED=$(df -h / 2>/dev/null | awk 'NR==2{print $3"/"$2" ("$5")"}')
    SVC_STATUS=\( (systemctl is-active zivpn 2>/dev/null && echo " \){GRN}● Active\( {RST}" || echo " \){RED}● Inactive${RST}")
    USER_COUNT=$(wc -l < "$DB" 2>/dev/null || echo "0")
    DATE_TIME=$(date +"%a %d %b %Y  %I:%M:%S %p %Z")
    FLAG=$(flag "$COUNTRY_CODE")
    LOC_STR="${FLAG} $CITY, $COUNTRY"
}


    echo "$pass|$exp|$quota|${devid:-None}" >> "$DB"
    systemctl restart zivpn 2>/dev/null

    echo -e "\n${CYN}в•”в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•—${RST}"
    echo -e "${CYN}в•‘  ${GRN}${BOLD}рҹҺү NEW USER CREATED SUCCESSFULLY рҹҺү${RST}${CYN}                 в•‘${RST}"
    echo -e "${CYN}в• в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•Ј${RST}"
    echo -e "${CYN}в•‘${RST} ${YLW}рҹ‘Ө Password   :${RST} ${WHT}$pass${RST}"
    echo -e "${CYN}в•‘${RST} ${YLW}вҸі Expiry     :${RST} ${WHT}$exp ($days Days)${RST}"
    echo -e "${CYN}в•‘${RST} ${YLW}рҹ“Ҡ Quota      :${RST} ${WHT}$quota${RST}"
    echo -e "${CYN}в•‘${RST} ${YLW}рҹ“ұ Device ID  :${RST} ${WHT}${devid:-None}${RST}"
    echo -e "${CYN}в• в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•Ј${RST}"
    echo -e "${CYN}в•‘${RST} ${MAG}рҹҢҚ Server IP  :${RST} ${WHT}$IP${RST}"
    echo -e "${CYN}в•‘${RST} ${MAG}рҹ“Қ Location   :${RST} ${WHT}$CITY, $COUNTRY${RST}"
    echo -e "${CYN}в•‘${RST} ${MAG}рҹҸў ISP        :${RST} ${WHT}$ISP${RST}"
    echo -e "${CYN}в•ҡв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•қ${RST}"
    echo ""
    read -p "Press Enter to continue..."
}

# --- Trial User ---
trial_user() {
    read -p "$(echo -e ${GRN}Minutes (1-60):${RST} )" mins
    pass="trial_$(openssl rand -hex 2)"
    if [ -f "$CONFIG" ]; then
        jq --arg p "$pass" '.auth.config += [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
        systemctl restart zivpn 2>/dev/null
    fi
    echo -e "${GRN}Trial Created: ${YLW}$pass${GRN} (Expires in $mins mins)${RST}"
    (
        sleep $((mins * 60))
        if [ -f "$CONFIG" ]; then
            jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
            systemctl restart zivpn 2>/dev/null
        fi
    ) &
    read -p "Press Enter to continue..."
}


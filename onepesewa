press_enter() { echo ""; read -rp "Press Enter to continue..." _; }

toggle_user_status() {
    echo -ne "\n  ${GRN}Enter full password: ${RST}"; read -r pass
    [ -z "$pass" ] && return
    if grep -q "^${pass}|" "$DB" 2>/dev/null; then
        current=\( (grep "^ \){pass}|" "$DB" | cut -d'|' -f7 || echo "active")
        if [ "$current" = "paused" ]; then
            new="active"
            echo -e "  \( {GRN}▶ Account Resumed \){RST}"
        else
            new="paused"
            echo -e "  \( {YLW}⏸️ Account Paused \){RST}"
            port=\( (grep "^ \){pass}|" "$DB" | cut -d'|' -f4)
            [ -n "$port" ] && conntrack -D -p udp --dport "$port" 2>/dev/null
        fi
        awk -F'|' -v p="$pass" -v st="$new" 'BEGIN{OFS="|"} $1==p{$7=st} {print}' "$DB" > /tmp/db.tmp && mv /tmp/db.tmp "$DB"
        systemctl restart zivpn 2>/dev/null
    else
        echo -e "  \( {RED}User not found. \){RST}"
    fi
    press_enter
}


# --- Display usage statistics ---
show_usage_stats() {
    update_usage_db
    echo -e "\n${CYN}в•ӯв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•®${RST}"
    echo -e "${CYN}в”Ӯ${RST} ${BOLD}Password                          | Used / Quota       | Port  | Expiry${RST}     ${CYN}в”Ӯ${RST}"
    echo -e "${CYN}в”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө${RST}"
    while IFS='|' read -r pass expiry quota port deviceid; do
        if [ -n "$pass" ]; then
            used_bytes=$(get_usage "$pass")
            quota_bytes=$(quota_to_bytes "$quota")
            used_fmt=$(format_bytes ${used_bytes:-0})
            if [ $quota_bytes -gt 0 ] && [ ${used_bytes:-0} -ge $quota_bytes ]; then
                status="${RED}EXCEEDED${RST}"
            else
                status="${GRN}OK${RST}"
            fi
            printf "${CYN}в”Ӯ${RST} %-33s | %-18s | %-5s | %-10s ${CYN}в”Ӯ${RST}\n" \
                "${pass:0:33}" "$used_fmt / $quota" "$port" "$expiry"
        fi
    done < "$DB"
    echo -e "${CYN}в•°в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв•Ҝ${RST}"
    echo ""
    read -p "Press Enter to continue..."
}

# --- Remove User (cleanup iptables) ---
remove_user() {
    read -p "$(echo -e "${GRN}Password to remove: ${RST}")" pass
    # Get port before deletion
    port=$(grep "^$pass|" "$DB" 2>/dev/null | cut -d'|' -f4)
    if [ -n "$port" ]; then
        remove_tracking "$port"
    fi
    [ -f "$CONFIG" ] && jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
    sed -i "/^$pass|/d" "$DB" 2>/dev/null
    sed -i "/^$pass|/d" "$USAGE_DB" 2>/dev/null
    systemctl restart zivpn 2>/dev/null
    echo -e "${GRN}User removed.${RST}"
    read -p "Press Enter to continue..."
}

# --- Install cron job for usage updates ---
install_cron() {
    cat > /etc/cron.d/opudp_usage <<EOF
* * * * * root /usr/local/bin/onepesewa --update-usage >/dev/null 2>&1
EOF
    chmod 644 /etc/cron.d/opudp_usage
}

# Trial User
trial_user() {
    read -p "$(echo -e "${GRN}Minutes (1-60): ${RST}")" mins
    pass="trial_$(openssl rand -hex 2)"
    port=$(find_free_port)
    if [ -z "$port" ]; then
        echo -e "${RED}No free ports!${RST}"
        read -p "Press Enter..."
        return
    fi
    if [ -f "$CONFIG" ]; then
        jq --arg p "$pass" '.auth.config += [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
    fi
    echo "$pass|$exp|100MB|$port|trial" >> "$DB"
    echo "$pass|0" >> "$USAGE_DB"
    setup_tracking "$pass" "$port"
    systemctl restart zivpn 2>/dev/null
    echo -e "${GRN}Trial Created: ${YLW}$pass${GRN} (Port $port, Expires in $mins mins)${RST}"
    ( sleep $((mins*60))
      remove_tracking "$port"
      [ -f "$CONFIG" ] && jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
      sed -i "/^$pass|/d" "$DB" 2>/dev/null
      sed -i "/^$pass|/d" "$USAGE_DB" 2>/dev/null
      systemctl restart zivpn 2>/dev/null
    ) &
    read -p "Press Enter to continue..."
}


#!/bin/bash
# в–Ҳв–Җв–Ҳ в–Ҳв–„в–‘в–Ҳ в–Ҳв–Җв–Җ в–Ҳв–Җв–Ҳ в–Ҳв–Җв–Җ в–Ҳв–Җ в–Ҳв–Җв–Җ в–Ҳв–‘в–Ҳв–‘в–Ҳ в–„в–Җв–Ҳ   в–Ҳв–‘в–Ҳ в–Ҳв–Җв–„ в–Ҳв–Җв–Ҳ
# в–Ҳв–„в–Ҳ в–Ҳв–‘в–Җв–Ҳ в–Ҳв–Ҳв–„ в–Ҳв–Җв–Җ в–Ҳв–Ҳв–„ в–„в–Ҳ в–Ҳв–Ҳв–„ в–Җв–„в–Җв–„в–Җ в–Ҳв–Җв–Ҳ   в–Ҳв–„в–Ҳ в–Ҳв–„в–Җ в–Ҳв–Җв–Җ
# OFFICIAL ONEPESEWA UDP PANEL вҖ“ ATTRACTIVE EDITION

CONFIG="/etc/zivpn/config.json"
DB="/etc/zivpn/users.db"

# --- Colors ---
BLK='\e[1;30m'   # Black
RED='\e[1;31m'   # Red
GRN='\e[1;32m'   # Green
YLW='\e[1;33m'   # Yellow
BLU='\e[1;34m'   # Blue
MAG='\e[1;35m'   # Magenta
CYN='\e[1;36m'   # Cyan
WHT='\e[1;37m'   # White
RST='\e[0m'      # Reset

# Rainbow array for title
COLORS=("$RED" "$GRN" "$YLW" "$BLU" "$MAG" "$CYN" "$WHT" "$RED" "$GRN" "$YLW" "$BLU" "$MAG" "$CYN")

# --- Auto-install dependencies ---
if ! command -v jq &>/dev/null; then
    apt-get install -y jq -qq &>/dev/null
fi
if ! command -v bc &>/dev/null; then
    apt-get install -y bc -qq &>/dev/null
fi

# --- Fetch System & Geo Data ---
GEO=$(curl -4 -s --max-time 8 "https://ipapi.co/json/" 2>/dev/null)
if [ -z "$GEO" ] || ! echo "$GEO" | grep -q '"ip"'; then
    IP="N/A"
    CITY="Unknown"
    COUNTRY="Unknown"
    ISP="Unknown"
else
    IP=$(echo "$GEO" | grep -oP '"ip":\s*"\K[^"]+')
    CITY=$(echo "$GEO" | grep -oP '"city":\s*"\K[^"]+')
    COUNTRY=$(echo "$GEO" | grep -oP '"country_name":\s*"\K[^"]+')
    ISP=$(echo "$GEO" | grep -oP '"org":\s*"\K[^"]+')
    [ -z "$IP" ] && IP="N/A"
    [ -z "$CITY" ] && CITY="Unknown"
    [ -z "$COUNTRY" ] && COUNTRY="Unknown"
    [ -z "$ISP" ] && ISP="Unknown"
fi

# OS & Kernel
OS_NAME=$(grep "^PRETTY_NAME" /etc/os-release | cut -d '"' -f 2)
KERNEL=$(uname -r)

# Uptime
UPTIME=$(uptime -p | sed 's/up //' | sed 's/ days/d/' | sed 's/ day/d/' | sed 's/ hours/h/' | sed 's/ hour/h/' | sed 's/ minutes/m/' | sed 's/ minute/m/')
[ -z "$UPTIME" ] && UPTIME="N/A"

# Service status & user count
if systemctl is-active --quiet zivpn; then
    STATUS="${GRN}в—Ҹ ACTIVE${RST}"
else
    STATUS="${RED}в—Ӣ INACTIVE${RST}"
fi
USER_COUNT=$(jq '.auth.config | length' "$CONFIG" 2>/dev/null || echo "0")

# Current date/time (live)
DATE_TIME=$(date +"%A, %d %B %Y  |  %H:%M:%S")


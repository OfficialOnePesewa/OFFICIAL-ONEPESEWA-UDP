    print_banner
    read -p "$(echo -e "${CYN}Enter choice [0-99]: ${RST}")" opt
    case $opt in
        1) systemctl start zivpn udp-custom; echo -e "${GRN}Services started.${RST}"; read -p "Press Enter..." ;;
        2) systemctl stop zivpn udp-custom; echo -e "${RED}Services stopped.${RST}"; read -p "Press Enter..." ;;
        3) systemctl restart zivpn udp-custom; echo -e "${GRN}Services restarted.${RST}"; read -p "Press Enter..." ;;
        4) systemctl status zivpn udp-custom; read -p "Press Enter..." ;;
        5) list_users ;;
        6) add_user ;;
        7) remove_user ;;
        8) renew_user ;;
        9) cleanup_expired ;;
        10) show_usage ;;
        11) speedtest-cli --simple; read -p "Press Enter..." ;;
        12) journalctl -u zivpn -u udp-custom -f ;;
        13) mkdir -p /root/opudp_backup; tar -czf "/root/opudp_backup/opudp_$(date +%Y%m%d).tar.gz" /etc/zivpn /etc/passwd /etc/shadow; echo -e "${GRN}Backup created.${RST}"; read -p "Press Enter..." ;;
        14) ls /root/opudp_backup/*.tar.gz 2>/dev/null; read -p "File to restore: " f; [ -f "$f" ] && { systemctl stop zivpn udp-custom; tar -xzf "$f" -C /; systemctl start zivpn udp-custom; echo "Restored."; }; read -p "Press Enter..." ;;
        15) wget -qO /usr/local/bin/onepesewa https://raw.githubusercontent.com/OfficialOnePesewa/OFFICIAL-ONEPESEWA-UDP/main/onepesewa && chmod +x /usr/local/bin/onepesewa && echo -e "${GRN}Updated. Restarting...${RST}"; sleep 2; exec onepesewa ;;
        16) trial_user ;;
        17) user_info ;;
        18) read -p "Bot Token: " t; echo "$t" > /etc/zivpn/telegram_token; systemctl enable opudp-bot 2>/dev/null; systemctl restart opudp-bot 2>/dev/null; echo -e "${GRN}Bot configured.${RST}"; read -p "Press Enter..." ;;
        99) systemctl stop zivpn udp-custom; rm -rf /etc/zivpn /usr/local/bin/zivpn /usr/local/bin/onepesewa /root/udp-custom*; echo -e "${RED}Uninstalled.${RST}"; exit ;;
        0) clear; echo "Goodbye!"; exit ;;
        *) echo -e "${RED}Invalid option.${RST}"; read -p "Press Enter..." ;;
    esac
done

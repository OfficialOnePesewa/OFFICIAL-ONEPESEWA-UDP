#!/bin/bash
# OP UDP PANEL – ZIVPN with Device Binding

CONFIG="/etc/zivpn/config.json"
DB="/etc/zivpn/users.db"
USAGE_DB="/etc/zivpn/usage.db"
BINDINGS="/etc/zivpn/bindings.json"
CACHE_FILE="/tmp/opudp_geo.cache"
CACHE_TTL=300
ADMIN_TELEGRAM="@OfficialOnePesewa"
DONATION_MSG="💛 Support VPS Hosting - Donations Welcome: Telecel Cash: 0502013764"

RED='\e[1;31m' GRN='\e[1;32m' YLW='\e[1;33m' BLU='\e[1;34m' MAG='\e[1;35m' CYN='\e[1;36m' WHT='\e[1;37m' RST='\e[0m'
BOLD='\e[1m' DIM='\e[2m'

command -v jq &>/dev/null || apt-get install -y jq -qq 2>/dev/null

fetch_geo() {
    if [ -f "$CACHE_FILE" ] && [ $(($(date +%s) - $(stat -c %Y "$CACHE_FILE" 2>/dev/null || echo 0))) -lt $CACHE_TTL ]; then
        source "$CACHE_FILE"
        return
    fi
    printf "${DIM}Fetching location...${RST}"
    GEO=""
    for api in "https://ipapi.co/json/" "https://ipinfo.io/json" "https://ifconfig.co/json"; do
        GEO=$(curl -4 -s --max-time 5 "$api" 2>/dev/null)
        if [ -n "$GEO" ] && echo "$GEO" | grep -qE '"ip"|"ip"'; then
            break
        fi
    done
    if [ -z "$GEO" ]; then
        IP=$(curl -4 -s ifconfig.me)
        CITY="Unknown"; COUNTRY="Unknown"; ISP="Unknown"; ZIP=""; COUNTRY_CODE=""
    else
        IP=$(echo "$GEO" | grep -oP '"ip":\s*"\K[^"]+' | head -1)
        CITY=$(echo "$GEO" | grep -oP '"city":\s*"\K[^"]+' | head -1)
        COUNTRY=$(echo "$GEO" | grep -oP '"country":\s*"\K[^"]+' | head -1)
        [ -z "$COUNTRY" ] && COUNTRY=$(echo "$GEO" | grep -oP '"country_name":\s*"\K[^"]+')
        COUNTRY_CODE=$(echo "$GEO" | grep -oP '"country_code":\s*"\K[^"]+' | tr '[:upper:]' '[:lower:]')
        ZIP=$(echo "$GEO" | grep -oP '"postal":\s*"\K[^"]+')
        ISP=$(echo "$GEO" | grep -oP '"org":\s*"\K[^"]+')
    fi
    [ -z "$IP" ] && IP="N/A"
    [ -z "$CITY" ] && CITY="Unknown"
    [ -z "$COUNTRY" ] && COUNTRY="Unknown"
    [ -z "$ISP" ] && ISP="Unknown"
    echo "IP=\"$IP\"; CITY=\"$CITY\"; COUNTRY=\"$COUNTRY\"; COUNTRY_CODE=\"$COUNTRY_CODE\"; ZIP=\"$ZIP\"; ISP=\"$ISP\"" > "$CACHE_FILE"
    printf "\r\033[K"
}

flag() {
    case $1 in
        us) echo "🇺🇸" ;; gb) echo "🇬🇧" ;; ca) echo "🇨🇦" ;; au) echo "🇦🇺" ;;
        de) echo "🇩🇪" ;; fr) echo "🇫🇷" ;; nl) echo "🇳🇱" ;; in) echo "🇮🇳" ;;
        jp) echo "🇯🇵" ;; br) echo "🇧🇷" ;; za) echo "🇿🇦" ;; sg) echo "🇸🇬" ;;
        gh) echo "🇬🇭" ;; ng) echo "🇳🇬" ;; ke) echo "🇰🇪" ;; il) echo "🇮🇱" ;;
        *) echo "" ;;
    esac
}

get_sysinfo() {
    OS_INFO=$(grep PRETTY_NAME /etc/os-release | cut -d'"' -f2)
    ARCH=$(uname -m)
    OS_FULL="$OS_INFO $ARCH"
    UPTIME=$(uptime -p | sed 's/up //; s/ days/d/; s/ day/d/; s/ hours/h/; s/ hour/h/; s/ minutes/m/; s/ minute/m/')
    [ -z "$UPTIME" ] && UPTIME="N/A"
    
    if systemctl is-active --quiet zivpn; then
        ZIVPN_STATUS="${GRN}🟢 active${RST}"
        ZIVPN_USERS=$(jq '.auth.config | length' "$CONFIG" 2>/dev/null || echo "0")
    else
        ZIVPN_STATUS="${RED}🔴 inactive${RST}"
        ZIVPN_USERS=0
    fi
    
    if systemctl is-active --quiet zivpn-proxy; then
        PROXY_STATUS="${GRN}🟢 active${RST}"
    else
        PROXY_STATUS="${RED}🔴 inactive${RST}"
    fi
    
    DATE_TIME=$(TZ="Africa/Accra" date +"%A, %d %B %Y  %I:%M:%S %p %Z")
    FLAG=$(flag "$COUNTRY_CODE")
    [ -n "$FLAG" ] && LOC_STR="${FLAG}  $CITY, $COUNTRY" || LOC_STR="$CITY, $COUNTRY"
}


    echo -e "${WHT}│${RST}  ${GRN}📡 ZIVPN       :${RST} $ZIVPN_STATUS  ${CYN}$ZIVPN_USERS users${RST}"
    echo -e "${WHT}│${RST}  ${BLU}🔷 UDP Custom  :${RST} $UDPC_STATUS  ${CYN}$UDPC_USERS users${RST}"
    echo -e "${WHT}│${RST}  ${MAG}🎯 ZIVPN Port  :${RST} 5667 (NAT $PORT_START-$PORT_END)${RST}"

#!/bin/bash
# ONEPESEWA Device Binding Guard – Blocks password sharing

DB="/etc/zivpn/users.db"
CONFIG="/etc/zivpn/config.json"
BLOCK_TIME=3600  # 1 hour in seconds
LOG_FILE="/var/log/onepesewa-guard.log"

log() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$LOG_FILE"
}

# Function to extract password and device ID from UDP payload
# ZIVPN handshake contains password and device ID; we capture with tcpdump
monitor() {
    # Capture UDP packets on port 5667, print payload as hex + ASCII
    tcpdump -i any -l -n -A -s 0 'udp port 5667' 2>/dev/null | while read line; do
        # Look for pattern: password string and device ID (heuristic)
        if echo "$line" | grep -q "onepesewa"; then
            # Extract password and device ID from the payload
            # This is a simplified extraction; real implementation may need adjustment
            payload=$(echo "$line" | grep -oP 'onepesewa.*')
            password=$(echo "$payload" | awk '{print $2}')
            devid=$(echo "$payload" | awk '{print $4}')
            src_ip=$(echo "$line" | awk '{print $3}' | cut -d. -f1-4)

            if [ -n "$password" ] && [ -n "$devid" ] && [ -n "$src_ip" ]; then
                # Check if password exists in DB
                db_entry=$(grep "^$password|" "$DB")
                if [ -n "$db_entry" ]; then
                    registered_devid=$(echo "$db_entry" | cut -d'|' -f4)
                    if [ "$devid" != "$registered_devid" ]; then
                        log "BLOCKED: IP $src_ip used password '$password' with wrong Device ID '$devid' (registered: '$registered_devid')"
                        iptables -I INPUT -s "$src_ip" -j DROP
                        (sleep $BLOCK_TIME; iptables -D INPUT -s "$src_ip" -j DROP) &
                    else
                        log "ALLOWED: IP $src_ip authenticated with correct Device ID"
                    fi
                fi
            fi
        fi
    done
}

# Start monitoring
log "Device Binding Guard started."
monitor

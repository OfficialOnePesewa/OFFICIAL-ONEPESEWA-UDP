# ============================================================

add_user() {
    echo -e "\n${Y}--- CREATE NEW USER ---${NC}"
    read -p "Password: " pass
    read -p "Validity (Days): " days
    read -p "Quota (e.g. 10GB or 500MB): " quota_input
    read -p "Device ID (Optional, press Enter to skip): " devid

    local exp quota_bytes
    exp=$(date -d "+$days days" +%Y-%m-%d)
    quota_bytes=$(quota_to_bytes "$quota_input")

    if [ -f "$CONFIG" ]; then
        jq --arg p "$pass" '.auth.config += [$p]' "$CONFIG" > /tmp/zivpn_tmp.json \
            && mv /tmp/zivpn_tmp.json "$CONFIG"
    fi

    # DB format: pass|exp|quota_bytes|devid|used_bytes
    (
        flock -x 200
        echo "$pass|$exp|$quota_bytes|${devid:-None}|0" >> "$DB"
    ) 200>"$LOCK"

    systemctl restart zivpn 2>/dev/null

    echo -e "\n${C}=========================================${NC}"
    echo -e "${G}${BOLD}       ūüéČ NEW USER SUCCESSFULLY ADDED ūüéČ${NC}"
    echo -e "${C}=========================================${NC}"
    echo -e "${Y} ūüĎ§ Password   :${NC} $pass"
    echo -e "${Y} ‚Ź≥ Expiry     :${NC} $exp ($days Days)"
    echo -e "${Y} ūüďä Quota      :${NC} $quota_input ($(bytes_to_human "$quota_bytes"))"
    echo -e "${Y} ūüďĪ Device ID  :${NC} ${devid:-None}"
    echo -e "${C}-----------------------------------------${NC}"
    echo -e "${M} ūüĆć Server IP  :${NC} $IP"
    echo -e "${M} ūüďć Location   :${NC} $CITY, $COUNTRY"
    echo -e "${C}=========================================${NC}"
}

remove_user() {
    read -p "Password to remove: " pass
    if [ -f "$CONFIG" ]; then
        jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" > /tmp/zivpn_tmp.json \
            && mv /tmp/zivpn_tmp.json "$CONFIG"
    fi
    (
        flock -x 200
        [ -f "$DB" ] && sed -i "/^$pass|/d" "$DB"
        # Remove from IP map too
        [ -f /etc/zivpn/ip_user.map ] && sed -i "/ $pass$/d" /etc/zivpn/ip_user.map
    ) 200>"$LOCK"
    systemctl restart zivpn 2>/dev/null
    echo -e "${G}User '$pass' removed.${NC}"
}

renew_user() {
    echo -e "\n${Y}--- RENEW / EXTEND USER ---${NC}"
    [ ! -f "$DB" ] && echo -e "${R}No user database found.${NC}" && return
    awk -F'|' '{print NR". "$1" | Exp: "$2}' "$DB"
    read -p "Enter password to renew: " pass
    read -p "Add how many days: " days

    if grep -q "^$pass|" "$DB"; then
        local OLD_EXP TODAY BASE NEW_EXP
        OLD_EXP=$(grep "^$pass|" "$DB" | cut -d'|' -f2)
        TODAY=$(date +%Y-%m-%d)
        BASE=$OLD_EXP
        [[ "$OLD_EXP" < "$TODAY" ]] && BASE="$TODAY"
        NEW_EXP=$(date -d "$BASE +$days days" +%Y-%m-%d)
        (
            flock -x 200
            sed -i "s/^$pass|$OLD_EXP|/$pass|$NEW_EXP|/" "$DB"
        ) 200>"$LOCK"
        echo -e "${G}‚úĒ '$pass' renewed ‚Üí new expiry: $NEW_EXP${NC}"
    else
        echo -e "${R}User not found.${NC}"
    fi
}

cleanup_expired() {
    echo -e "\n${Y}--- CLEANUP EXPIRED USERS ---${NC}"
    [ ! -f "$DB" ] && echo -e "${R}No user database found.${NC}" && return
    local TODAY COUNT=0
    TODAY=$(date +%Y-%m-%d)
    local tmpfile
    tmpfile=$(mktemp)

    while IFS='|' read -r pass exp quota devid used; do
        if [[ "$exp" < "$TODAY" ]]; then
            [ -f "$CONFIG" ] && jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" \
                > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
            [ -f /etc/zivpn/ip_user.map ] && sed -i "/ $pass$/d" /etc/zivpn/ip_user.map
            echo -e "${R}Removed: $pass (expired $exp)${NC}"
            COUNT=$((COUNT + 1))
        else
            echo "$pass|$exp|$quota|${devid:-None}|${used:-0}" >> "$tmpfile"
        fi
    done < "$DB"

    (flock -x 200; mv "$tmpfile" "$DB") 200>"$LOCK"
    [ "$COUNT" -gt 0 ] && systemctl restart zivpn 2>/dev/null
    echo -e "${G}Done. Removed $COUNT expired user(s).${NC}"
}

# ============================================================
# OPTION 11 ‚ÄĒ BANDWIDTH + EXPIRY (with live usage tracking)
# ============================================================

bandwidth_expiry() {
    echo -e "\n${Y}--- BANDWIDTH + EXPIRY INFO ---${NC}"
    [ ! -f "$DB" ] || [ ! -s "$DB" ] && echo -e "${R}No users found.${NC}" && return

    local TODAY
    TODAY=$(date +%Y-%m-%d)

    printf "\n${C}%-18s %-12s %-9s %-9s %-9s %-20s %s${NC}\n" \
        "Password" "Expiry" "Quota" "Used" "Left" "Progress" "Status"
    echo "$(printf '%0.s‚ĒÄ' {1..100})"

    while IFS='|' read -r pass exp quota devid used; do
        used="${used:-0}"
        quota="${quota:-0}"

        local quota_h used_h left_h bar status_str
        quota_h=$(bytes_to_human "$quota")
        used_h=$(bytes_to_human "$used")

        if [ "$quota" -gt 0 ]; then
            local left=$(( quota - used ))
            [ "$left" -lt 0 ] && left=0
            left_h=$(bytes_to_human "$left")
            bar=$(progress_bar "$used" "$quota")
        else
            left_h="‚ąě"
            bar="[Unlimited      ]"
        fi

        local days_left=0
        if [[ "$exp" > "$TODAY" ]]; then
            days_left=$(( ( $(date -d "$exp" +%s) - $(date +%s) ) / 86400 ))
        fi

        # Determine status
        if [[ "$exp" < "$TODAY" ]]; then
            status_str="${R}EXPIRED${NC}"
        elif [ "$quota" -gt 0 ] && [ "$used" -ge "$quota" ]; then
            status_str="${R}QUOTA FULL${NC}"
        else
            status_str="${G}Active (${days_left}d)${NC}"
        fi

        printf "%-18s %-12s %-9s %-9s %-9s %-20s " \
            "$pass" "$exp" "$quota_h" "$used_h" "$left_h" "$bar"
        echo -e "$status_str"

    done < "$DB"
    echo ""
    echo -e "${Y}ūüď° Bandwidth monitor updates every 60 seconds.${NC}"
}

# ============================================================
# OPTION 12 ‚ÄĒ RESET BANDWIDTH (per user)
# ============================================================

reset_bandwidth() {
    echo -e "\n${Y}--- RESET USER BANDWIDTH ---${NC}"
    [ ! -f "$DB" ] || [ ! -s "$DB" ] && echo -e "${R}No users found.${NC}" && return
    echo -e "${C}Current users:${NC}"
    awk -F'|' '{print NR". "$1" | Used: "$5" bytes"}' "$DB"
    echo ""
    read -p "Enter password to reset (or 'all' to reset everyone): " target

    local tmpfile
    tmpfile=$(mktemp)
    (
        flock -x 200
        while IFS='|' read -r p exp quota devid used; do
            if [ "$target" = "all" ] || [ "$p" = "$target" ]; then
                echo "$p|$exp|$quota|${devid:-None}|0" >> "$tmpfile"
                echo -e "${G}Reset: $p${NC}"
            else
                echo "$p|$exp|$quota|${devid:-None}|${used:-0}" >> "$tmpfile"
            fi
        done < "$DB"
        mv "$tmpfile" "$DB"
    ) 200>"$LOCK"
    # Also zero iptables counters
    iptables -Z ZIVPN_USAGE 2>/dev/null
}


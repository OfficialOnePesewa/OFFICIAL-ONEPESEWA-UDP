change_port_range() {
    read -p "New start port: " START
    read -p "New end port: "   END
    iptables -t nat -D PREROUTING -p udp --dport 6000:19999 -j DNAT --to-destination :5667 2>/dev/null
    iptables -D INPUT -p udp --dport 6000:19999 -j ACCEPT 2>/dev/null
    iptables -I INPUT -p udp --dport "${START}:${END}" -j ACCEPT
    iptables -t nat -A PREROUTING -p udp --dport "${START}:${END}" -j DNAT --to-destination :5667
    netfilter-persistent save 2>/dev/null
    echo -e "${G}‚úĒ NAT port range: ${START}-${END}${NC}"
}

set_conn_limit() {
    read -p "Max connections per IP (0 = no limit): " LIMIT
    iptables -D INPUT -p udp --dport 5667 -m connlimit --connlimit-above 1 -j DROP 2>/dev/null
    if [ "$LIMIT" -gt 0 ]; then
        iptables -I INPUT -p udp --dport 5667 -m connlimit --connlimit-above "$LIMIT" -j DROP
        netfilter-persistent save 2>/dev/null
        echo -e "${G}‚úĒ Limit: $LIMIT per IP${NC}"
    else
        echo -e "${G}‚úĒ Limit removed.${NC}"
    fi
}

trial_user() {
    read -p "Minutes (1-60): " mins
    local pass="trial_$(openssl rand -hex 2)"
    if [ -f "$CONFIG" ]; then
        jq --arg p "$pass" '.auth.config += [$p]' "$CONFIG" > /tmp/zivpn_tmp.json \
            && mv /tmp/zivpn_tmp.json "$CONFIG"
        systemctl restart zivpn 2>/dev/null
    fi
    local exp
    exp=$(date -d "+${mins} minutes" +"%Y-%m-%d %H:%M")
    # Add trial user to DB with 0 quota (unlimited for trial)
    (flock -x 200; echo "$pass|$exp|0|Trial|0" >> "$DB") 200>"$LOCK"
    echo -e "${G}Trial: ${Y}$pass${G} | Expires: $exp${NC}"
    (
        sleep $((mins * 60))
        [ -f "$CONFIG" ] && jq --arg p "$pass" '.auth.config -= [$p]' "$CONFIG" \
            > /tmp/zivpn_tmp.json && mv /tmp/zivpn_tmp.json "$CONFIG"
        systemctl restart zivpn 2>/dev/null
        (flock -x 200; sed -i "/^$pass|/d" "$DB") 200>"$LOCK"
    ) &
}

# ============================================================
# STARTUP ‚ÄĒ ensure monitor is running
# ============================================================
setup_monitor

# ============================================================
# MAIN MENU
# ============================================================
while true; do
    banner
    echo -e " ${G}1)${NC}  Start ZIVPN         ${G}11)${NC} Bandwidth + Expiry"
    echo -e " ${G}2)${NC}  Stop ZIVPN          ${G}12)${NC} Reset User Bandwidth"
    echo -e " ${G}3)${NC}  Restart ZIVPN       ${G}13)${NC} Speed Test"
    echo -e " ${G}4)${NC}  Status              ${G}14)${NC} Live Logs"
    echo -e " ${G}5)${NC}  List Users          ${G}15)${NC} Backup All Data"
    echo -e " ${G}6)${NC}  Add User            ${G}16)${NC} Restore Backup"
    echo -e " ${G}7)${NC}  Remove User         ${G}17)${NC} Change Port Range"
    echo -e " ${G}8)${NC}  Renew / Extend User ${Y}18)${NC} Auto-Update Panel"
    echo -e " ${G}9)${NC}  Cleanup Expired     ${G}19)${NC} Set Connection Limit"
    echo -e " ${G}10)${NC} Connection Stats    ${G}20)${NC} Trial User (1-60m)"
    echo -e "${C}----------------------------------------------------------------${NC}"
    echo -e " ${R}99) UNINSTALL${NC}           ${G}0) Exit${NC}"
    echo -e "${C}----------------------------------------------------------------${NC}"
    read -p " Choose [0-99]: " opt

    case $opt in
        1)  systemctl start   zivpn 2>/dev/null && echo -e "${G}ZIVPN Started.${NC}"   || echo -e "${R}Service not found.${NC}" ;;
        2)  systemctl stop    zivpn 2>/dev/null && echo -e "${R}ZIVPN Stopped.${NC}"   || echo -e "${R}Service not found.${NC}" ;;
        3)  systemctl restart zivpn 2>/dev/null && echo -e "${G}ZIVPN Restarted.${NC}" || echo -e "${R}Service not found.${NC}" ;;
        4)  systemctl status  zivpn 2>/dev/null || echo -e "${R}Service not found.${NC}" ;;
        5)
            if [ -f "$DB" ] && [ -s "$DB" ]; then
                echo -e "\n${C}Password           | Expiry     | Quota      | Used       | DeviceID${NC}"
                echo "-----------------------------------------------------------------------"
                while IFS='|' read -r p exp quota devid used; do
                    printf "%-18s | %-10s | %-10s | %-10s | %s\n" \
                        "$p" "$exp" "$(bytes_to_human "${quota:-0}")" \
                        "$(bytes_to_human "${used:-0}")" "${devid:-None}"
                done < "$DB"
            else
                echo -e "${R}No users found.${NC}"
            fi
            ;;
        6)  add_user ;;
        7)  remove_user ;;
        8)  renew_user ;;
        9)  cleanup_expired ;;
        10) connection_stats ;;
        11) bandwidth_expiry ;;
        12) reset_bandwidth ;;
        13) speed_test ;;
        14) journalctl -u zivpn -f 2>/dev/null || echo -e "${R}Service not found.${NC}" ;;
        15) backup_data ;;
        16) restore_backup ;;
        17) change_port_range ;;
        18)
            echo -e "${Y}Updating panel...${NC}"
            wget -qO /usr/local/bin/opudp \
                https://raw.githubusercontent.com/OfficialOnePesewa/udp-zivpn/main/opudp
            wget -qO /usr/local/bin/opudp-monitor \
                https://raw.githubusercontent.com/OfficialOnePesewa/udp-zivpn/main/opudp-monitor
            chmod +x /usr/local/bin/opudp /usr/local/bin/opudp-monitor
            systemctl restart opudp-monitor 2>/dev/null
            echo -e "${G}Updated! Restarting...${NC}"
            sleep 2; exec opudp
            ;;
        19) set_conn_limit ;;
        20) trial_user ;;
        99)
            read -p "Type 'yes' to confirm UNINSTALL: " confirm
            if [ "$confirm" = "yes" ]; then
                systemctl stop    zivpn opudp-monitor 2>/dev/null
                systemctl disable zivpn opudp-monitor 2>/dev/null
                rm -f /etc/systemd/system/zivpn.service
                rm -f /etc/systemd/system/opudp-monitor.service
                rm -rf /etc/zivpn
                rm -f /usr/local/bin/zivpn
                rm -f /usr/local/bin/opudp
                rm -f /usr/local/bin/opudp-monitor
                systemctl daemon-reload
                echo -e "${R}Fully uninstalled.${NC}"
                exit 0
            else
                echo -e "${Y}Cancelled.${NC}"
            fi
            ;;
        0) goodbye; exit 0 ;;
        *) echo -e "${R}Invalid option.${NC}" ;;
    esac
    echo ""
    read -p "Press Enter to return to menu..."
done

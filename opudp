# --- Auto-install jq ---
if ! command -v jq &>/dev/null; then
    apt-get install -y jq -qq &>/dev/null
fi

# --- Geo-IP with fallback ---
GEO=$(curl -4 -s --max-time 8 "https://ipapi.co/json/" 2>/dev/null)
IP=$(echo "$GEO" | grep -oP '"ip":\s*"\K[^"]+')
if [ -z "$IP" ]; then
    GEO=$(curl -4 -s --max-time 8 "http://ip-api.com/json/" 2>/dev/null)
    IP=$(echo "$GEO"      | grep -oP '"query":\s*"\K[^"]+')
    CITY=$(echo "$GEO"    | grep -oP '"city":\s*"\K[^"]+')
    COUNTRY=$(echo "$GEO" | grep -oP '"country":\s*"\K[^"]+')
    ISP=$(echo "$GEO"     | grep -oP '"isp":\s*"\K[^"]+')
else
    CITY=$(echo "$GEO"    | grep -oP '"city":\s*"\K[^"]+')
    COUNTRY=$(echo "$GEO" | grep -oP '"country_name":\s*"\K[^"]+')
    ISP=$(echo "$GEO"     | grep -oP '"org":\s*"\K[^"]+')
fi
[ -z "$IP" ]      && IP="N/A"
[ -z "$CITY" ]    && CITY="Unknown"
[ -z "$COUNTRY" ] && COUNTRY="Unknown"
[ -z "$ISP" ]     && ISP="Unknown"
OS_INFO=$(grep "PRETTY_NAME" /etc/os-release | cut -d '"' -f 2)

# ============================================================
# HELPERS
# ============================================================

quota_to_bytes() {
    local q="${1^^}"
    if [[ "$q" =~ ^([0-9]+)GB$ ]]; then echo $(( ${BASH_REMATCH[1]} * 1073741824 ))
    elif [[ "$q" =~ ^([0-9]+)MB$ ]]; then echo $(( ${BASH_REMATCH[1]} * 1048576 ))
    elif [[ "$q" =~ ^([0-9]+)$ ]];   then echo "${BASH_REMATCH[1]}"
    else echo "0"; fi
}

bytes_to_human() {
    local b=${1:-0}
    if   [ "$b" -ge 1073741824 ]; then printf "%.2fGB" "$(echo "scale=2; $b/1073741824" | bc)"
    elif [ "$b" -ge 1048576 ];    then printf "%.2fMB" "$(echo "scale=2; $b/1048576" | bc)"
    elif [ "$b" -ge 1024 ];       then printf "%.2fKB" "$(echo "scale=2; $b/1024" | bc)"
    else printf "%dB" "$b"; fi
}

progress_bar() {
    local used=$1 total=$2 width=16
    [ "${total:-0}" -eq 0 ] && printf "[????????????????] N/A" && return
    local pct=$(( used * 100 / total ))
    [ "$pct" -gt 100 ] && pct=100
    local filled=$(( pct * width / 100 ))
    local empty=$(( width - filled ))
    local bar=""
    for ((i=0; i<filled; i++)); do bar="${bar}‚Ėą"; done
    for ((i=0; i<empty;  i++)); do bar="${bar}‚ĖĎ"; done
    printf "[%s] %d%%" "$bar" "$pct"
}

# ============================================================
# MONITOR SETUP
# ============================================================

setup_monitor() {
    if [ ! -f /usr/local/bin/opudp-monitor ]; then
        echo -e "${Y}Downloading bandwidth monitor...${NC}"
        wget -qO /usr/local/bin/opudp-monitor \
            https://raw.githubusercontent.com/OfficialOnePesewa/udp-zivpn/main/opudp-monitor
        chmod +x /usr/local/bin/opudp-monitor
    fi

    if [ ! -f /etc/systemd/system/opudp-monitor.service ]; then
        cat <<EOF > /etc/systemd/system/opudp-monitor.service
[Unit]
Description=OPUDP Bandwidth Monitor
After=zivpn.service

[Service]
ExecStart=/usr/local/bin/opudp-monitor
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
EOF
        systemctl daemon-reload
        systemctl enable opudp-monitor &>/dev/null
        systemctl start  opudp-monitor &>/dev/null
    fi

    systemctl is-active opudp-monitor &>/dev/null || \
        systemctl start opudp-monitor &>/dev/null
}

